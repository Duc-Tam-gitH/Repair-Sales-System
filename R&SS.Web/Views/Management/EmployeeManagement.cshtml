@model ManagementViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Employee Management";
    ViewData["ActiveRole"] = "Management";
    ViewData["RoleDisplay"] = "Manager";
}

@section Styles {
    <link rel="stylesheet" href="~/css/EmployeeManagement.css" asp-append-version="true" />
}

<section class="employee-management-page">
    <div class="admin-hero"><div><span>Employees</span><h1>Employee Management</h1><p>Review employee records, roles, specialization, and work status.</p></div></div>
    <div class="table-card table-responsive mt-4"><table class="table align-middle"><thead><tr><th>Code</th><th>Name</th><th>Email</th><th>Phone</th><th>Specialization</th><th>Status</th></tr></thead><tbody>@foreach (var employee in Model.Employees) { <tr><td>@employee.EmployeeCode</td><td>@employee.FullName</td><td>@employee.Email</td><td>@(employee.Phone ?? "-")</td><td>@(employee.Specialization ?? "-")</td><td><span class="badge @(employee.IsActive ? "text-bg-success" : "text-bg-secondary")">@employee.WorkStatus</span></td></tr> } @if (!Model.Employees.Any()) { <tr><td colspan="6" class="text-center text-muted">No employees found.</td></tr> }</tbody></table></div>
</section>
