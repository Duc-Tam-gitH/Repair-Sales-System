@model ManagementViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Quản lý nhân viên";
    ViewData["ActiveRole"] = "Management";
    ViewData["RoleDisplay"] = "Quản lý";
}

@section Styles {
    <link rel="stylesheet" href="~/css/EmployeeManagement.css" asp-append-version="true" />
}

<section class="employee-management-page">
    <div class="admin-hero"><div><span>Nhân viên</span><h1>Quản lý nhân viên</h1><p>Xem hồ sơ nhân viên, vai trò, chuyên môn và trạng thái làm việc.</p></div></div>
    <div class="table-card table-responsive mt-4"><table class="table align-middle"><thead><tr><th>Mã</th><th>Tên</th><th>Email</th><th>Điện thoại</th><th>Chuyên môn</th><th>Trạng thái</th></tr></thead><tbody>@foreach (var employee in Model.Employees) { <tr><td>@employee.EmployeeCode</td><td>@employee.FullName</td><td>@employee.Email</td><td>@(employee.Phone ?? "-")</td><td>@(employee.Specialization ?? "-")</td><td><span class="badge @(employee.IsActive ? "text-bg-success" : "text-bg-secondary")">@employee.WorkStatus</span></td></tr> } @if (!Model.Employees.Any()) { <tr><td colspan="6" class="text-center text-muted">Không tìm thấy nhân viên.</td></tr> }</tbody></table></div>
</section>
