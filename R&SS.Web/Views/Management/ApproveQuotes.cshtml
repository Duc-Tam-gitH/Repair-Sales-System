@model ManagementViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Duyệt báo giá";
    ViewData["ActiveRole"] = "Management";
    ViewData["RoleDisplay"] = "Quản lý";
    var quotedRepairs = Model.RepairOrders.Where(repair => repair.TotalAmount > 0 || repair.ServiceFee > 0).ToArray();
}

@section Styles {
    <link rel="stylesheet" href="~/css/ApproveQuotes.css" asp-append-version="true" />
}

<section class="approve-quotes-page">
    <div class="admin-hero"><div><span>Báo giá</span><h1>Duyệt báo giá</h1><p>Xem báo giá sửa chữa và tổng phí dịch vụ hiện được ghi nhận trong hệ thống.</p></div></div>
    <div class="table-card table-responsive mt-4"><table class="table align-middle"><thead><tr><th>Mã sửa chữa</th><th>Khách hàng</th><th>Thiết bị</th><th>Phí dịch vụ</th><th>Tổng cộng</th><th>Trạng thái</th></tr></thead><tbody>@foreach (var repair in quotedRepairs) { <tr><td>@repair.RepairOrderCode</td><td>@(repair.Customer?.FullName ?? "-")</td><td>@repair.DeviceType</td><td>@repair.ServiceFee.ToString("C")</td><td>@repair.TotalAmount.ToString("C")</td><td>@repair.Status</td></tr> } @if (!quotedRepairs.Any()) { <tr><td colspan="6" class="text-center text-muted">Không tìm thấy báo giá sửa chữa.</td></tr> }</tbody></table></div>
</section>
