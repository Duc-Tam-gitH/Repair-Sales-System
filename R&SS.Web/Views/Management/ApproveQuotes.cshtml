@model ManagementViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Approve Quotes";
    ViewData["ActiveRole"] = "Management";
    ViewData["RoleDisplay"] = "Manager";
    var quotedRepairs = Model.RepairOrders.Where(repair => repair.TotalAmount > 0 || repair.ServiceFee > 0).ToArray();
}

@section Styles {
    <link rel="stylesheet" href="~/css/ApproveQuotes.css" asp-append-version="true" />
}

<section class="approve-quotes-page">
    <div class="admin-hero"><div><span>Quotes</span><h1>Approve Quotes</h1><p>Review repair quotes and service totals currently recorded in the system.</p></div></div>
    <div class="table-card table-responsive mt-4"><table class="table align-middle"><thead><tr><th>Repair Code</th><th>Customer</th><th>Device</th><th>Service Fee</th><th>Total</th><th>Status</th></tr></thead><tbody>@foreach (var repair in quotedRepairs) { <tr><td>@repair.RepairOrderCode</td><td>@(repair.Customer?.FullName ?? "-")</td><td>@repair.DeviceType</td><td>@repair.ServiceFee.ToString("C")</td><td>@repair.TotalAmount.ToString("C")</td><td>@repair.Status</td></tr> } @if (!quotedRepairs.Any()) { <tr><td colspan="6" class="text-center text-muted">No repair quotes found.</td></tr> }</tbody></table></div>
</section>
