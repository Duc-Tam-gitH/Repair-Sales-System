@model ManagementViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = Model.Account.UserId.HasValue ? "Sửa tài khoản" : "Thêm tài khoản";
    ViewData["ActiveRole"] = "Management";
    ViewData["RoleDisplay"] = "Quản lý";
}

@section Styles {
    <link rel="stylesheet" href="~/css/AddAccount.css" asp-append-version="true" />
}

<section class="add-account-page">
    <div class="form-card">
        <div class="form-title"><span>Tài khoản</span><h1>@ViewData["Title"]</h1><p>Tạo hoặc cập nhật tài khoản người dùng hệ thống.</p></div>
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
        <form method="post" asp-controller="Management" asp-action="AddAccount">
            @Html.AntiForgeryToken()
            <input type="hidden" name="UserId" value="@Model.Account.UserId" />
            <div class="row g-3">
                <div class="col-md-4"><label class="form-label">Tên đăng nhập</label><input class="form-control" name="Username" value="@Model.Account.Username" required /></div>
                <div class="col-md-4"><label class="form-label">Mật khẩu</label><input class="form-control" name="Password" type="password" placeholder="Bắt buộc với tài khoản mới" /></div>
                <div class="col-md-4"><label class="form-label">Vai trò</label><select class="form-select" name="RoleName" required><option value="">Chọn vai trò</option>@foreach (var role in Model.Roles) { <option value="@role.RoleName" selected="@(role.RoleName == Model.Account.RoleName)">@role.RoleName</option> }</select></div>
                <div class="col-md-6"><label class="form-label">Họ tên</label><input class="form-control" name="FullName" value="@Model.Account.FullName" required /></div>
                <div class="col-md-6"><label class="form-label">Email</label><input class="form-control" name="Email" value="@Model.Account.Email" type="email" required /></div>
                <div class="col-md-6"><label class="form-label">Điện thoại</label><input class="form-control" name="Phone" value="@Model.Account.Phone" /></div>
                <div class="col-md-6 d-flex align-items-end"><label class="form-check"><input class="form-check-input" name="IsActive" type="checkbox" value="true" checked="@Model.Account.IsActive" /> Đang hoạt động</label></div>
            </div>
            <div class="d-flex gap-2 mt-4"><button class="btn btn-primary" type="submit">Lưu tài khoản</button><a class="btn btn-outline-secondary" asp-controller="Management" asp-action="SystemAccountManagement">Hủy</a></div>
        </form>
    </div>
</section>
