@model ManagementViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Customer Management";
    ViewData["ActiveRole"] = "Management";
    ViewData["RoleDisplay"] = "Manager";
}

@section Styles {
    <link rel="stylesheet" href="~/css/CustomerManagement.css" asp-append-version="true" />
}

<section class="customer-management-page">
    <div class="admin-hero"><div><span>Customers</span><h1>Customer Management</h1><p>Review customer profiles, order counts, repair counts, and active status.</p></div></div>
    <div class="table-card table-responsive mt-4"><table class="table align-middle"><thead><tr><th>Customer</th><th>Email</th><th>Phone</th><th>Orders</th><th>Repairs</th><th>Status</th></tr></thead><tbody>@foreach (var customer in Model.Customers) { <tr><td>@customer.FullName</td><td>@customer.Email</td><td>@(customer.Phone ?? "-")</td><td>@Model.SalesOrders.Count(order => order.CustomerId == customer.CustomerId)</td><td>@Model.RepairOrders.Count(repair => repair.CustomerId == customer.CustomerId)</td><td><span class="badge @(customer.IsActive ? "text-bg-success" : "text-bg-secondary")">@(customer.IsActive ? "Active" : "Inactive")</span></td></tr> }</tbody></table></div>
</section>
