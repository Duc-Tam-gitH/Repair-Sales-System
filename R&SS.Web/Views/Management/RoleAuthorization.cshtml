@model ManagementViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Role Authorization";
    ViewData["ActiveRole"] = "Management";
    ViewData["RoleDisplay"] = "Manager";
}

@section Styles {
    <link rel="stylesheet" href="~/css/RoleAuthorization.css" asp-append-version="true" />
}

<section class="role-authorization-page">
    <div class="admin-hero"><div><span>Roles</span><h1>Role Authorization</h1><p>Review roles and account assignments.</p></div></div>
    <div class="table-card table-responsive mt-4"><table class="table align-middle"><thead><tr><th>Role</th><th>Description</th><th>Assigned Users</th></tr></thead><tbody>@foreach (var role in Model.Roles) { <tr><td>@role.RoleName</td><td>@(role.Description ?? "-")</td><td>@Model.Users.Count(user => user.UserRoles.Any(userRole => userRole.RoleId == role.RoleId))</td></tr> }</tbody></table></div>
</section>
