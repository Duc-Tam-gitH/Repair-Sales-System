@model ManagementViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Phân quyền vai trò";
    ViewData["ActiveRole"] = "Management";
    ViewData["RoleDisplay"] = "Quản lý";
}

@section Styles {
    <link rel="stylesheet" href="~/css/RoleAuthorization.css" asp-append-version="true" />
}

<section class="role-authorization-page">
    <div class="admin-hero"><div><span>Vai trò</span><h1>Phân quyền vai trò</h1><p>Xem vai trò và phân công tài khoản.</p></div></div>
    <div class="table-card table-responsive mt-4"><table class="table align-middle"><thead><tr><th>Vai trò</th><th>Mô tả</th><th>Người dùng được phân công</th></tr></thead><tbody>@foreach (var role in Model.Roles) { <tr><td>@role.RoleName</td><td>@(role.Description ?? "-")</td><td>@Model.Users.Count(user => user.UserRoles.Any(userRole => userRole.RoleId == role.RoleId))</td></tr> }</tbody></table></div>
</section>
