@model ManagementViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Management Dashboard";
    ViewData["ActiveRole"] = "Management";
    ViewData["RoleDisplay"] = "Manager";
}

@section Styles {
    <link rel="stylesheet" href="~/css/ManagementDashboard.css" asp-append-version="true" />
}

<section class="management-dashboard-page">
    <div class="admin-hero"><div><span>Operations</span><h1>Management Dashboard</h1><p>Monitor accounts, customers, repairs, requests, and sales performance.</p></div></div>
    <div class="row g-4"><div class="col-md-3"><article class="summary-card"><span>Users</span><strong>@Model.Users.Count</strong></article></div><div class="col-md-3"><article class="summary-card"><span>Customers</span><strong>@Model.Customers.Count</strong></article></div><div class="col-md-3"><article class="summary-card"><span>Active Repairs</span><strong>@Model.RepairOrders.Count(repair => !repair.Status.Contains("Completed", StringComparison.OrdinalIgnoreCase))</strong></article></div><div class="col-md-3"><article class="summary-card"><span>Sales Revenue</span><strong>@Model.SalesOrders.Sum(order => order.TotalAmount).ToString("C")</strong></article></div></div>
    <section class="table-card table-responsive mt-4"><h2>Recent Repair Orders</h2><table class="table"><thead><tr><th>Code</th><th>Customer</th><th>Device</th><th>Status</th></tr></thead><tbody>@foreach (var repair in Model.RepairOrders.OrderByDescending(repair => repair.ReceivedDate).Take(8)) { <tr><td>@repair.RepairOrderCode</td><td>@(repair.Customer?.FullName ?? "Customer")</td><td>@repair.DeviceType</td><td>@repair.Status</td></tr> }</tbody></table></section>
</section>
