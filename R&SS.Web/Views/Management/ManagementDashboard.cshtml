@model ManagementViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Bảng điều khiển quản lý";
    ViewData["ActiveRole"] = "Management";
    ViewData["RoleDisplay"] = "Quản lý";
}

@section Styles {
    <link rel="stylesheet" href="~/css/ManagementDashboard.css" asp-append-version="true" />
}

<section class="management-dashboard-page">
    <div class="admin-hero"><div><span>Vận hành</span><h1>Bảng điều khiển quản lý</h1><p>Theo dõi tài khoản, khách hàng, sửa chữa, yêu cầu và hiệu quả bán hàng.</p></div></div>
    <div class="row g-4"><div class="col-md-3"><article class="summary-card"><span>Người dùng</span><strong>@Model.Users.Count</strong></article></div><div class="col-md-3"><article class="summary-card"><span>Khách hàng</span><strong>@Model.Customers.Count</strong></article></div><div class="col-md-3"><article class="summary-card"><span>Sửa chữa đang xử lý</span><strong>@Model.RepairOrders.Count(repair => !repair.Status.Contains("Completed", StringComparison.OrdinalIgnoreCase))</strong></article></div><div class="col-md-3"><article class="summary-card"><span>Doanh thu bán hàng</span><strong>@Model.SalesOrders.Sum(order => order.TotalAmount).ToString("C")</strong></article></div></div>
    <section class="table-card table-responsive mt-4"><h2>Đơn sửa chữa gần đây</h2><table class="table"><thead><tr><th>Mã</th><th>Khách hàng</th><th>Thiết bị</th><th>Trạng thái</th></tr></thead><tbody>@foreach (var repair in Model.RepairOrders.OrderByDescending(repair => repair.ReceivedDate).Take(8)) { <tr><td>@repair.RepairOrderCode</td><td>@(repair.Customer?.FullName ?? "Khách hàng")</td><td>@repair.DeviceType</td><td>@repair.Status</td></tr> }</tbody></table></section>
</section>
