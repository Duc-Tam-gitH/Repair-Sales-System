@model ManagementViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Repair Progress Dashboard";
    ViewData["ActiveRole"] = "Management";
    ViewData["RoleDisplay"] = "Manager";
}

@section Styles {
    <link rel="stylesheet" href="~/css/RepairProgressDashboard.css" asp-append-version="true" />
}

<section class="repair-progress-dashboard-page">
    <div class="admin-hero"><div><span>Repair Progress</span><h1>Repair Progress Dashboard</h1><p>Track repair workload and current ticket statuses.</p></div></div>
    <div class="row g-4"><div class="col-md-4"><article class="summary-card"><span>Total Repairs</span><strong>@Model.RepairOrders.Count</strong></article></div><div class="col-md-4"><article class="summary-card"><span>Completed</span><strong>@Model.RepairOrders.Count(repair => repair.CompletedDate.HasValue || repair.Status.Contains("Completed", StringComparison.OrdinalIgnoreCase))</strong></article></div><div class="col-md-4"><article class="summary-card"><span>Unassigned</span><strong>@Model.RepairOrders.Count(repair => !repair.AssignedTechnicianId.HasValue)</strong></article></div></div>
    <section class="table-card table-responsive mt-4"><table class="table"><thead><tr><th>Code</th><th>Customer</th><th>Technician</th><th>Status</th><th>Updated</th></tr></thead><tbody>@foreach (var repair in Model.RepairOrders.OrderByDescending(repair => repair.UpdatedAt)) { <tr><td>@repair.RepairOrderCode</td><td>@(repair.Customer?.FullName ?? "-")</td><td>@(repair.AssignedTechnician?.Username ?? "Unassigned")</td><td>@repair.Status</td><td>@repair.UpdatedAt.ToString("yyyy-MM-dd")</td></tr> }</tbody></table></section>
</section>
