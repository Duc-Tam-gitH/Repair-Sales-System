@model ManagementViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Bảng tiến độ sửa chữa";
    ViewData["ActiveRole"] = "Management";
    ViewData["RoleDisplay"] = "Quản lý";
}

@section Styles {
    <link rel="stylesheet" href="~/css/RepairProgressDashboard.css" asp-append-version="true" />
}

<section class="repair-progress-dashboard-page">
    <div class="admin-hero"><div><span>Tiến độ sửa chữa</span><h1>Bảng tiến độ sửa chữa</h1><p>Theo dõi khối lượng sửa chữa và trạng thái phiếu hiện tại.</p></div></div>
    <div class="row g-4"><div class="col-md-4"><article class="summary-card"><span>Tổng sửa chữa</span><strong>@Model.RepairOrders.Count</strong></article></div><div class="col-md-4"><article class="summary-card"><span>Hoàn tất</span><strong>@Model.RepairOrders.Count(repair => repair.CompletedDate.HasValue || repair.Status.Contains("Completed", StringComparison.OrdinalIgnoreCase))</strong></article></div><div class="col-md-4"><article class="summary-card"><span>Chưa phân công</span><strong>@Model.RepairOrders.Count(repair => !repair.AssignedTechnicianId.HasValue)</strong></article></div></div>
    <section class="table-card table-responsive mt-4"><table class="table"><thead><tr><th>Mã</th><th>Khách hàng</th><th>Kỹ thuật viên</th><th>Trạng thái</th><th>Cập nhật</th></tr></thead><tbody>@foreach (var repair in Model.RepairOrders.OrderByDescending(repair => repair.UpdatedAt)) { <tr><td>@repair.RepairOrderCode</td><td>@(repair.Customer?.FullName ?? "-")</td><td>@(repair.AssignedTechnician?.Username ?? "Chưa phân công")</td><td>@repair.Status</td><td>@repair.UpdatedAt.ToString("yyyy-MM-dd")</td></tr> }</tbody></table></section>
</section>
