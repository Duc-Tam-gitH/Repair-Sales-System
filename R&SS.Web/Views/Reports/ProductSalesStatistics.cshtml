@model ProductSalesStatisticsViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Product Sales Statistics";
    ViewData["ActiveRole"] = "Reports";
    ViewData["RoleDisplay"] = "Reports Staff";
    var grouped = Model.Details
        .GroupBy(detail => detail.ProductId)
        .Select(group => new
        {
            Product = group.First().Product,
            Quantity = group.Sum(detail => detail.Quantity),
            Revenue = group.Sum(detail => detail.LineTotal)
        })
        .OrderByDescending(item => item.Quantity)
        .ToArray();
    var totalQuantity = grouped.Sum(item => item.Quantity);
    var totalRevenue = grouped.Sum(item => item.Revenue);
}

@section Styles {
    <link rel="stylesheet" href="~/css/ProductSalesStatistics.css" asp-append-version="true" />
}

<section class="report-page product-sales-page">
    <div class="report-hero"><div><span>Product Analytics</span><h1>Product Sales Statistics</h1><p>Analyze top products, product revenue, category sales, and product performance.</p></div></div>
    <div class="filter-panel"><a class="btn btn-primary" asp-controller="Reports" asp-action="ProductSalesStatistics">Generate Report</a></div>
    <div class="row g-4"><div class="col-md-4"><article class="summary-card"><span>Total Products Sold</span><strong>@totalQuantity</strong></article></div><div class="col-md-4"><article class="summary-card revenue"><span>Total Product Revenue</span><strong>@totalRevenue.ToString("C")</strong></article></div><div class="col-md-4"><article class="summary-card avg"><span>Average Price / Product</span><strong>@(totalQuantity == 0 ? 0 : totalRevenue / totalQuantity)</strong></article></div></div>
    <section class="table-card mt-4 table-responsive"><h2>Top 5 Best-Selling Products</h2><table class="table align-middle"><thead><tr><th>Rank</th><th>Product Name</th><th>Category</th><th>Quantity Sold</th><th>Revenue</th></tr></thead><tbody>@foreach (var item in grouped.Take(5).Select((value, index) => new { value, index })) { <tr><td><span class="rank">@(item.index + 1)</span></td><td>@(item.value.Product?.ProductName ?? "Product")</td><td>@(item.value.Product?.ProductCategory?.CategoryName ?? "Uncategorized")</td><td>@item.value.Quantity</td><td>@item.value.Revenue.ToString("C")</td></tr> } @if (!grouped.Any()) { <tr><td colspan="5" class="text-center text-muted">No product sales found.</td></tr> }</tbody></table></section>
    <div class="row g-4 mt-1"><div class="col-lg-7"><section class="table-card table-responsive"><h2>Product Sales Table</h2><table class="table"><thead><tr><th>Product Code</th><th>Product Name</th><th>Unit Price</th><th>Quantity Sold</th><th>Revenue</th></tr></thead><tbody>@foreach (var item in grouped) { <tr><td>@(item.Product?.ProductCode ?? "-")</td><td>@(item.Product?.ProductName ?? "Product")</td><td>@(item.Product?.SalePrice.ToString("C") ?? "-")</td><td>@item.Quantity</td><td>@item.Revenue.ToString("C")</td></tr> }</tbody></table></section></div><div class="col-lg-5"><section class="chart-card"><h2>Revenue by Product</h2><div class="bar-chart">@foreach (var item in grouped.Take(5)) { var height = totalRevenue == 0 ? 5 : Math.Max(5, (int)(item.Revenue / totalRevenue * 100)); <i style="height:@height%"></i> }</div></section></div></div>
</section>
