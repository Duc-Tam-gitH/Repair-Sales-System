@model ProductSalesStatisticsViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Thống kê bán sản phẩm";
    ViewData["ActiveRole"] = "Reports";
    ViewData["RoleDisplay"] = "Nhân viên báo cáo";
    var grouped = Model.Details
        .GroupBy(detail => detail.ProductId)
        .Select(group => new
        {
            Product = group.First().Product,
            Quantity = group.Sum(detail => detail.Quantity),
            Revenue = group.Sum(detail => detail.LineTotal)
        })
        .OrderByDescending(item => item.Quantity)
        .ToArray();
    var totalQuantity = grouped.Sum(item => item.Quantity);
    var totalRevenue = grouped.Sum(item => item.Revenue);
}

@section Styles {
    <link rel="stylesheet" href="~/css/ProductSalesStatistics.css" asp-append-version="true" />
}

<section class="report-page product-sales-page">
    <div class="report-hero"><div><span>Phân tích sản phẩm</span><h1>Thống kê bán sản phẩm</h1><p>Phân tích sản phẩm bán chạy, doanh thu sản phẩm, doanh số theo danh mục và hiệu quả sản phẩm.</p></div></div>
    <div class="filter-panel"><a class="btn btn-primary" asp-controller="Reports" asp-action="ProductSalesStatistics">Tạo báo cáo</a></div>
    <div class="row g-4"><div class="col-md-4"><article class="summary-card"><span>Tổng sản phẩm đã bán</span><strong>@totalQuantity</strong></article></div><div class="col-md-4"><article class="summary-card revenue"><span>Tổng doanh thu sản phẩm</span><strong>@totalRevenue.ToString("C")</strong></article></div><div class="col-md-4"><article class="summary-card avg"><span>Giá trung bình / sản phẩm</span><strong>@(totalQuantity == 0 ? 0 : totalRevenue / totalQuantity)</strong></article></div></div>
    <section class="table-card mt-4 table-responsive"><h2>Top 5 sản phẩm bán chạy</h2><table class="table align-middle"><thead><tr><th>Hạng</th><th>Tên sản phẩm</th><th>Danh mục</th><th>Số lượng đã bán</th><th>Doanh thu</th></tr></thead><tbody>@foreach (var item in grouped.Take(5).Select((value, index) => new { value, index })) { <tr><td><span class="rank">@(item.index + 1)</span></td><td>@(item.value.Product?.ProductName ?? "Sản phẩm")</td><td>@(item.value.Product?.ProductCategory?.CategoryName ?? "Chưa phân loại")</td><td>@item.value.Quantity</td><td>@item.value.Revenue.ToString("C")</td></tr> } @if (!grouped.Any()) { <tr><td colspan="5" class="text-center text-muted">Không tìm thấy dữ liệu bán sản phẩm.</td></tr> }</tbody></table></section>
    <div class="row g-4 mt-1"><div class="col-lg-7"><section class="table-card table-responsive"><h2>Bảng bán sản phẩm</h2><table class="table"><thead><tr><th>Mã sản phẩm</th><th>Tên sản phẩm</th><th>Đơn giá</th><th>Số lượng đã bán</th><th>Doanh thu</th></tr></thead><tbody>@foreach (var item in grouped) { <tr><td>@(item.Product?.ProductCode ?? "-")</td><td>@(item.Product?.ProductName ?? "Sản phẩm")</td><td>@(item.Product?.SalePrice.ToString("C") ?? "-")</td><td>@item.Quantity</td><td>@item.Revenue.ToString("C")</td></tr> }</tbody></table></section></div><div class="col-lg-5"><section class="chart-card"><h2>Doanh thu theo sản phẩm</h2><div class="bar-chart">@foreach (var item in grouped.Take(5)) { var height = totalRevenue == 0 ? 5 : Math.Max(5, (int)(item.Revenue / totalRevenue * 100)); <i style="height:@height%"></i> }</div></section></div></div>
</section>
