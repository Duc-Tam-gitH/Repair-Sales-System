@model RepairReportViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Repair Report";
    ViewData["ActiveRole"] = "Reports";
    ViewData["RoleDisplay"] = "Reports Staff";
    var repairs = Model.Repairs;
    var completed = repairs.Count(repair => repair.Status.Contains("Completed", StringComparison.OrdinalIgnoreCase) || repair.CompletedDate.HasValue);
}

@section Styles {
    <link rel="stylesheet" href="~/css/RepairReport.css" asp-append-version="true" />
}

<section class="report-page repair-report-page">
    <div class="report-hero"><div><span>Repair Analytics</span><h1>Repair Report</h1><p>Track repair counts, status distribution, technician workload, and completion rates.</p></div></div>
    <div class="filter-panel"><a class="btn btn-primary" asp-controller="Reports" asp-action="RepairReport">Generate Report</a></div>
    <div class="row g-4"><div class="col-md-3"><article class="summary-card"><span>Total Repairs</span><strong>@repairs.Count</strong></article></div><div class="col-md-3"><article class="summary-card pending"><span>Pending Repairs</span><strong>@repairs.Count(repair => repair.Status.Contains("Pending", StringComparison.OrdinalIgnoreCase) || repair.Status.Contains("Received", StringComparison.OrdinalIgnoreCase))</strong></article></div><div class="col-md-3"><article class="summary-card progress"><span>In-Progress Repairs</span><strong>@repairs.Count(repair => repair.Status.Contains("Progress", StringComparison.OrdinalIgnoreCase) || repair.Status.Contains("Repair", StringComparison.OrdinalIgnoreCase))</strong></article></div><div class="col-md-3"><article class="summary-card complete"><span>Completion Rate</span><strong>@(repairs.Count == 0 ? 0 : completed * 100 / repairs.Count)%</strong></article></div></div>
    <section class="table-card mt-4 table-responsive"><h2>Repair Details</h2><table class="table align-middle"><thead><tr><th>Report Code</th><th>Customer</th><th>Device</th><th>Technician</th><th>Status</th><th>Completion Date</th></tr></thead><tbody>@foreach (var repair in repairs.OrderByDescending(repair => repair.ReceivedDate)) { <tr><td>@repair.RepairOrderCode</td><td>@(repair.Customer?.FullName ?? "Customer")</td><td>@repair.DeviceType</td><td>@(repair.AssignedTechnician?.Username ?? "Unassigned")</td><td>@repair.Status</td><td>@(repair.CompletedDate?.ToString("yyyy-MM-dd") ?? "Pending")</td></tr> } @if (!repairs.Any()) { <tr><td colspan="6" class="text-center text-muted">No repairs found.</td></tr> }</tbody></table></section>
    <section class="table-card mt-4 table-responsive"><h2>Technician Performance</h2><table class="table"><thead><tr><th>Technician</th><th>Tasks Assigned</th><th>Tasks Completed</th><th>Completion Rate</th></tr></thead><tbody>@foreach (var group in repairs.Where(repair => repair.AssignedTechnician is not null).GroupBy(repair => repair.AssignedTechnician!.Username)) { var done = group.Count(repair => repair.CompletedDate.HasValue); <tr><td>@group.Key</td><td>@group.Count()</td><td>@done</td><td>@(group.Count() == 0 ? 0 : done * 100 / group.Count())%</td></tr> }</tbody></table></section>
</section>
