@model RepairReportViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Báo cáo sửa chữa";
    ViewData["ActiveRole"] = "Reports";
    ViewData["RoleDisplay"] = "Nhân viên báo cáo";
    var repairs = Model.Repairs;
    var completed = repairs.Count(repair => repair.Status.Contains("Completed", StringComparison.OrdinalIgnoreCase) || repair.CompletedDate.HasValue);
}

@section Styles {
    <link rel="stylesheet" href="~/css/RepairReport.css" asp-append-version="true" />
}

<section class="report-page repair-report-page">
    <div class="report-hero"><div><span>Phân tích sửa chữa</span><h1>Báo cáo sửa chữa</h1><p>Theo dõi số lượng sửa chữa, phân bố trạng thái, khối lượng công việc của kỹ thuật viên và tỷ lệ hoàn tất.</p></div></div>
    <div class="filter-panel"><a class="btn btn-primary" asp-controller="Reports" asp-action="RepairReport">Tạo báo cáo</a></div>
    <div class="row g-4"><div class="col-md-3"><article class="summary-card"><span>Tổng sửa chữa</span><strong>@repairs.Count</strong></article></div><div class="col-md-3"><article class="summary-card pending"><span>Sửa chữa đang chờ</span><strong>@repairs.Count(repair => repair.Status.Contains("Đang chờ", StringComparison.OrdinalIgnoreCase) || repair.Status.Contains("Received", StringComparison.OrdinalIgnoreCase))</strong></article></div><div class="col-md-3"><article class="summary-card progress"><span>Sửa chữa đang xử lý</span><strong>@repairs.Count(repair => repair.Status.Contains("Progress", StringComparison.OrdinalIgnoreCase) || repair.Status.Contains("Sửa chữa", StringComparison.OrdinalIgnoreCase))</strong></article></div><div class="col-md-3"><article class="summary-card complete"><span>Tỷ lệ hoàn tất</span><strong>@(repairs.Count == 0 ? 0 : completed * 100 / repairs.Count)%</strong></article></div></div>
    <section class="table-card mt-4 table-responsive"><h2>Chi tiết sửa chữa</h2><table class="table align-middle"><thead><tr><th>Mã báo cáo</th><th>Khách hàng</th><th>Thiết bị</th><th>Kỹ thuật viên</th><th>Trạng thái</th><th>Ngày hoàn tất</th></tr></thead><tbody>@foreach (var repair in repairs.OrderByDescending(repair => repair.ReceivedDate)) { <tr><td>@repair.RepairOrderCode</td><td>@(repair.Customer?.FullName ?? "Khách hàng")</td><td>@repair.DeviceType</td><td>@(repair.AssignedTechnician?.Username ?? "Chưa phân công")</td><td>@repair.Status</td><td>@(repair.CompletedDate?.ToString("yyyy-MM-dd") ?? "Đang chờ")</td></tr> } @if (!repairs.Any()) { <tr><td colspan="6" class="text-center text-muted">Không tìm thấy sửa chữa.</td></tr> }</tbody></table></section>
    <section class="table-card mt-4 table-responsive"><h2>Hiệu suất kỹ thuật viên</h2><table class="table"><thead><tr><th>Kỹ thuật viên</th><th>Việc được giao</th><th>Việc đã hoàn tất</th><th>Tỷ lệ hoàn tất</th></tr></thead><tbody>@foreach (var group in repairs.Where(repair => repair.AssignedTechnician is not null).GroupBy(repair => repair.AssignedTechnician!.Username)) { var done = group.Count(repair => repair.CompletedDate.HasValue); <tr><td>@group.Key</td><td>@group.Count()</td><td>@done</td><td>@(group.Count() == 0 ? 0 : done * 100 / group.Count())%</td></tr> }</tbody></table></section>
</section>
