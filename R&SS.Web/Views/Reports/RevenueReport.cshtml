@{
    Layout = "_Layout";
    ViewData["Title"] = "Revenue Report";
    ViewData["ActiveRole"] = "Reports";
    ViewData["RoleDisplay"] = "Reports Staff";
}

@section Styles {
    <link rel="stylesheet" href="~/css/RevenueReport.css" asp-append-version="true" />
}

<!-- Data fetched via IRevenueReportService.GetRevenueByDateRange() -->
<section class="report-page revenue-report-page">
    <div class="report-hero"><div><span>Financial Analytics</span><h1>Revenue Report</h1><p>Analyze order, repair, and service revenue by period.</p></div></div>
    <div class="alert alert-success" role="status">Report generated successfully! Data exported to Excel successfully!</div>
    <div class="filter-panel">
        <select class="form-select"><option>Today</option><option>This Week</option><option>This Month</option><option>This Quarter</option><option>This Year</option><option>Custom Range</option></select>
        <input class="form-control" type="date" />
        <input class="form-control" type="date" />
        <button class="btn btn-primary">Generate Report</button>
        <div class="dropdown"><button class="btn btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown">Export Report</button><ul class="dropdown-menu"><li><a class="dropdown-item" href="#">Export as PDF</a></li><li><a class="dropdown-item" href="#">Export as Excel</a></li><li><a class="dropdown-item" href="#">Export as CSV</a></li></ul></div>
    </div>
    <div class="row g-4">
        <div class="col-md-3"><article class="summary-card"><span>Total Revenue</span><strong>$48,920</strong></article></div>
        <div class="col-md-3"><article class="summary-card"><span>Revenue from Orders</span><strong>$31,440</strong></article></div>
        <div class="col-md-3"><article class="summary-card"><span>Revenue from Repairs</span><strong>$14,680</strong></article></div>
        <div class="col-md-3"><article class="summary-card"><span>Revenue from Services</span><strong>$2,800</strong></article></div>
    </div>
    <div class="row g-4 mt-1">
        <div class="col-lg-6"><section class="chart-card"><h2>Revenue by Day</h2><div class="bar-chart"><i style="height:45%"></i><i style="height:68%"></i><i style="height:52%"></i><i style="height:80%"></i><i style="height:64%"></i><i style="height:90%"></i><i style="height:74%"></i></div></section></div>
        <div class="col-lg-6"><section class="chart-card"><h2>Revenue by Month</h2><div class="bar-chart monthly"><i style="height:35%"></i><i style="height:48%"></i><i style="height:55%"></i><i style="height:76%"></i><i style="height:64%"></i><i style="height:88%"></i></div></section></div>
    </div>
    <section class="table-card mt-4 table-responsive"><h2>Revenue Details</h2><table class="table align-middle"><thead><tr><th>Date</th><th>Order Revenue</th><th>Repair Revenue</th><th>Service Revenue</th><th>Total Revenue</th></tr></thead><tbody><tr><td>2026-07-18</td><td>$4,800</td><td>$1,240</td><td>$300</td><td>$6,340</td></tr><tr><td>2026-07-17</td><td>$3,920</td><td>$980</td><td>$220</td><td>$5,120</td></tr></tbody></table><button class="btn btn-info">Analyze Revenue</button><div class="analysis-box mt-3">Revenue increased by 12% compared to last month.</div></section>
</section>
