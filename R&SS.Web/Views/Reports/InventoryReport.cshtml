@model InventoryReportViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Báo cáo tồn kho";
    ViewData["ActiveRole"] = "Reports";
    ViewData["RoleDisplay"] = "Nhân viên báo cáo";
    var items = Model.Report.Items;
}

@section Styles {
    <link rel="stylesheet" href="~/css/InventoryReport.css" asp-append-version="true" />
}

<section class="report-page inventory-report-page">
    <div class="report-hero"><div><span>Phân tích tồn kho</span><h1>Báo cáo tồn kho</h1><p>Xem tồn kho hiện tại, lịch sử biến động và giá trị ước tính.</p></div></div>
    <form class="filter-panel" method="get" asp-controller="Reports" asp-action="InventoryReport"><select class="form-select" name="stockStatus"><option value="all">Tất cả tồn kho</option><option value="low">Sắp hết hàng</option></select><button class="btn btn-primary" type="submit">Tạo báo cáo</button></form>
    <div class="row g-4"><div class="col-md-3"><article class="summary-card"><span>Tổng số lượng tồn kho</span><strong>@items.Sum(item => item.StockQuantity)</strong></article></div><div class="col-md-3"><article class="summary-card"><span>Tổng sản phẩm</span><strong>@items.Count</strong></article></div><div class="col-md-3"><article class="summary-card low"><span>Mặt hàng sắp hết</span><strong>@items.Count(item => item.InventoryStatus == "Sắp hết hàng")</strong></article></div><div class="col-md-3"><article class="summary-card empty"><span>Mặt hàng hết hàng</span><strong>@items.Count(item => item.StockQuantity <= 0)</strong></article></div></div>
    <section class="table-card mt-4 table-responsive"><h2>Chi tiết tồn kho</h2><table class="table align-middle"><thead><tr><th>Mã mặt hàng</th><th>Tên mặt hàng</th><th>Nhập kho</th><th>Xuất kho</th><th>Số lượng hiện tại</th><th>Trạng thái</th></tr></thead><tbody>@foreach (var item in items) { <tr><td>@item.ProductCode</td><td>@item.ProductName</td><td>@item.ReceiptQuantity</td><td>@item.IssueQuantity</td><td>@item.StockQuantity</td><td>@item.InventoryStatus</td></tr> } @if (!items.Any()) { <tr><td colspan="6" class="text-center text-muted">@Model.Report.Message</td></tr> }</tbody></table></section>
    <section class="table-card mt-4 table-responsive"><h2>Biến động tồn kho</h2><div class="value-box">Tổng giá trị ước tính của tồn kho hiện tại: <strong>@Model.EstimatedValue.ToString("C")</strong></div></section>
</section>
