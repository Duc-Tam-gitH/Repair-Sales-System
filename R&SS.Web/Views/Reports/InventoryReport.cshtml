@{
    Layout = "_Layout";
    ViewData["Title"] = "Inventory Report";
    ViewData["ActiveRole"] = "Reports";
    ViewData["RoleDisplay"] = "Reports Staff";
}

@section Styles {
    <link rel="stylesheet" href="~/css/InventoryReport.css" asp-append-version="true" />
}

<!-- Data fetched via IInventoryReportService.GetInventoryReport() -->
<section class="report-page inventory-report-page">
    <div class="report-hero"><div><span>Inventory Analytics</span><h1>Inventory Report</h1><p>Review current stock, aging inventory, movement history, and estimated value.</p></div></div>
    <div class="filter-panel"><select class="form-select"><option>All Categories</option><option>Phones</option><option>Laptops</option><option>Components</option></select><button class="btn btn-primary">Generate Report</button><div class="dropdown"><button class="btn btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown">Export Report</button><ul class="dropdown-menu"><li><a class="dropdown-item" href="#">Export as PDF</a></li><li><a class="dropdown-item" href="#">Export as Excel</a></li><li><a class="dropdown-item" href="#">Export as CSV</a></li></ul></div></div>
    <div class="row g-4"><div class="col-md-3"><article class="summary-card"><span>Total Items in Stock</span><strong>12,480</strong></article></div><div class="col-md-3"><article class="summary-card"><span>Total Categories</span><strong>18</strong></article></div><div class="col-md-3"><article class="summary-card low"><span>Low Stock Items</span><strong>28</strong></article></div><div class="col-md-3"><article class="summary-card empty"><span>Out of Stock Items</span><strong>7</strong></article></div></div>
    <section class="table-card mt-4 table-responsive"><h2>Inventory Details</h2><table class="table align-middle"><thead><tr><th>Item Code</th><th>Item Name</th><th>Category</th><th>Current Quantity</th><th>Minimum Stock</th><th>Status</th></tr></thead><tbody><tr><td>CMP-014</td><td>Dell Keyboard Module</td><td>Components</td><td>3</td><td>10</td><td>Low Stock</td></tr><tr><td>CMP-118</td><td>OLED Screen Assembly</td><td>Components</td><td>0</td><td>6</td><td>Out of Stock</td></tr></tbody></table></section>
    <section class="table-card mt-4 table-responsive"><h2>View Long-Term Inventory</h2><table class="table"><tbody><tr><td>Legacy Charger</td><td>135 days in stock</td><td>Quantity: 22</td></tr><tr><td>Old Tablet Case</td><td>112 days in stock</td><td>Quantity: 17</td></tr></tbody></table></section>
    <section class="table-card mt-4 table-responsive"><h2>Inventory Movement</h2><table class="table"><thead><tr><th>Date</th><th>Item Name</th><th>Transaction Type</th><th>Quantity Changed</th><th>New Balance</th></tr></thead><tbody><tr><td>2026-07-18</td><td>Dell Keyboard Module</td><td>Inbound</td><td>+10</td><td>13</td></tr><tr><td>2026-07-18</td><td>OLED Screen Assembly</td><td>Outbound</td><td>-1</td><td>0</td></tr></tbody></table><div class="value-box">Total estimated value of current stock: <strong>$184,650</strong></div></section>
</section>
