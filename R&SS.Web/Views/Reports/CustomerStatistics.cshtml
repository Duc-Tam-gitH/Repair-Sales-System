@model CustomerStatisticsViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Customer Statistics";
    ViewData["ActiveRole"] = "Reports";
    ViewData["RoleDisplay"] = "Reports Staff";
    var activeCustomerIds = Model.Orders.Select(order => order.CustomerId).Concat(Model.Repairs.Select(repair => repair.CustomerId)).Distinct().ToHashSet();
}

@section Styles {
    <link rel="stylesheet" href="~/css/CustomerStatistics.css" asp-append-version="true" />
}

<section class="report-page customer-statistics-page">
    <div class="report-hero"><div><span>Customer Analytics</span><h1>Customer Statistics</h1><p>Measure customer growth, activity, repairs, orders, and spending.</p></div></div>
    <div class="filter-panel"><a class="btn btn-primary" asp-controller="Reports" asp-action="CustomerStatistics">Generate Report</a></div>
    <div class="row g-4"><div class="col-md-3"><article class="summary-card"><span>Total Customers</span><strong>@Model.Customers.Count</strong></article></div><div class="col-md-3"><article class="summary-card"><span>New Customers</span><strong>@Model.Customers.Count(customer => customer.CreatedAt >= DateTime.UtcNow.AddDays(-30))</strong></article></div><div class="col-md-3"><article class="summary-card active"><span>Active Customers</span><strong>@activeCustomerIds.Count</strong></article></div><div class="col-md-3"><article class="summary-card inactive"><span>Inactive Customers</span><strong>@(Model.Customers.Count - activeCustomerIds.Count)</strong></article></div></div>
    <section class="table-card mt-4 table-responsive"><h2>Customer Statistics</h2><table class="table align-middle"><thead><tr><th>Customer Name</th><th>Total Orders</th><th>Total Repairs</th><th>Total Spent</th><th>Last Activity</th></tr></thead><tbody>@foreach (var customer in Model.Customers.OrderBy(customer => customer.FullName)) { var orders = Model.Orders.Where(order => order.CustomerId == customer.CustomerId).ToArray(); var repairs = Model.Repairs.Where(repair => repair.CustomerId == customer.CustomerId).ToArray(); var last = orders.Select(order => order.SalesDate).Concat(repairs.Select(repair => repair.ReceivedDate)).DefaultIfEmpty(customer.CreatedAt).Max(); <tr><td>@customer.FullName</td><td>@orders.Length</td><td>@repairs.Length</td><td>@orders.Sum(order => order.TotalAmount).ToString("C")</td><td>@last.ToString("yyyy-MM-dd")</td></tr> } @if (!Model.Customers.Any()) { <tr><td colspan="5" class="text-center text-muted">No customers found.</td></tr> }</tbody></table></section>
    <div class="row g-4 mt-1"><div class="col-lg-6"><section class="chart-card"><h2>New Customers Over Time</h2><div class="line-chart"><i style="height:30%"></i><i style="height:45%"></i><i style="height:42%"></i><i style="height:66%"></i><i style="height:74%"></i></div></section></div><div class="col-lg-6"><section class="table-card"><h2>Additional Statistics</h2><p><strong>Average spending/customer:</strong> @(Model.Customers.Count == 0 ? 0 : Model.Orders.Sum(order => order.TotalAmount) / Model.Customers.Count)</p><p><strong>Highest spender:</strong> @(Model.Customers.OrderByDescending(customer => Model.Orders.Where(order => order.CustomerId == customer.CustomerId).Sum(order => order.TotalAmount)).FirstOrDefault()?.FullName ?? "-")</p></section></div></div>
</section>
