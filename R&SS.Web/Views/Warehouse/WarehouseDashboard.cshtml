@model WarehouseDashboardViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Warehouse Dashboard";
    ViewData["ActiveRole"] = "Warehouse";
    ViewData["RoleDisplay"] = "Warehouse Staff";
    var lowStockProducts = Model.Products
        .Where(product => product.QuantityInStock <= 5)
        .OrderBy(product => product.QuantityInStock)
        .Take(5)
        .ToArray();
}

@section Styles {
    <link rel="stylesheet" href="~/css/WarehouseDashboard.css" asp-append-version="true" />
}

<section class="warehouse-dashboard-page">
    <div class="warehouse-hero">
        <div><span>Inventory Control</span><h1>Warehouse Dashboard</h1><p>Monitor stock levels, inventory value, low-stock alerts, and warehouse actions.</p></div>
        <a class="btn btn-light" asp-controller="Warehouse" asp-action="InventoryManagement">Receive Goods</a>
    </div>

    <div class="row g-4">
        <div class="col-md-6 col-xl-3"><article class="warehouse-card"><span>Total Stock</span><strong>@Model.TotalStockQuantity</strong><small>Units in inventory</small></article></div>
        <div class="col-md-6 col-xl-3"><article class="warehouse-card low"><span>Items Running Low</span><strong>@Model.LowStockCount</strong><small>Five units or fewer</small></article></div>
        <div class="col-md-6 col-xl-3"><article class="warehouse-card empty"><span>Out-of-Stock Items</span><strong>@Model.OutOfStockCount</strong><small>Need urgent reorder</small></article></div>
        <div class="col-md-6 col-xl-3"><article class="warehouse-card value"><span>Total Inventory Value</span><strong>@Model.EstimatedInventoryValue.ToString("C")</strong><small>Estimated sale value</small></article></div>
    </div>

    <section class="alerts-panel mt-4">
        <h2>Inventory Alerts</h2>
        @if (lowStockProducts.Length == 0)
        {
            <div class="alert alert-success" role="alert">No low-stock items found.</div>
        }
        else
        {
            <div class="alert alert-warning" role="alert">Low inventory alert: please reorder soon.</div>
            @foreach (var product in lowStockProducts)
            {
                <div class="alert-row @(product.QuantityInStock <= 0 ? "danger" : string.Empty)">
                    <div><strong>@product.ProductName @(product.QuantityInStock <= 0 ? "is out of stock" : "is running low")</strong><p>Quantity: @product.QuantityInStock</p></div>
                    <a class="btn btn-sm @(product.QuantityInStock <= 0 ? "btn-outline-danger" : "btn-outline-primary")" asp-controller="Warehouse" asp-action="InventoryDetails" asp-route-id="@product.ProductId">View</a>
                </div>
            }
        }
    </section>
</section>
