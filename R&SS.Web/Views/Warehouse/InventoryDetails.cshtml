@{
    Layout = "_Layout";
    ViewData["Title"] = "Inventory Details";
    ViewData["ActiveRole"] = "Warehouse";
    ViewData["RoleDisplay"] = "Warehouse Staff";
}

@section Styles {
    <link rel="stylesheet" href="~/css/InventoryDetails.css" asp-append-version="true" />
}

<!-- Data fetched via IWarehouseService.GetIncomingGoodsReceiptDetails() -->
<section class="inventory-details-page">
    <div class="receipt-hero">
        <div><span>Receipt Code</span><h1>REC-2026-001</h1><p>Supplier: TechParts Co. • Receipt Date: 2026-07-18</p></div>
        <strong>Pending</strong>
    </div>
    <div class="details-card table-responsive">
        <h2>Product List</h2>
        <table class="table align-middle"><thead><tr><th>Product Name</th><th>Quantity</th><th>Unit Price</th><th>Total Amount</th></tr></thead><tbody><tr><td>Dell Keyboard Module</td><td>10</td><td>$45</td><td>$450</td></tr><tr><td>Nova X Battery</td><td>20</td><td>$22</td><td>$440</td></tr><tr><td>USB-C Service Kit</td><td>30</td><td>$12</td><td>$360</td></tr></tbody></table>
        <div class="receipt-total"><span>Total Amount</span><strong>$1,250</strong></div>
        <div class="d-flex gap-2 mt-4"><button class="btn btn-success">Confirm Receipt</button><a class="btn btn-outline-secondary" asp-controller="Warehouse" asp-action="InventoryManagement">Back to List</a></div>
    </div>
</section>
