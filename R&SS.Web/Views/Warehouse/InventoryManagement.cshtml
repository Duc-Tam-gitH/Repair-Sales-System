@model WarehouseInventoryViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Inventory Management";
    ViewData["ActiveRole"] = "Warehouse";
    ViewData["RoleDisplay"] = "Warehouse Staff";
}

@section Styles {
    <link rel="stylesheet" href="~/css/InventoryManagement.css" asp-append-version="true" />
}

<section class="inventory-management-page">
    <div class="inventory-header"><h1>Inventory Management</h1><p>Create stock receipts, issue stock, or adjust current product quantities.</p></div>
    @if (TempData["SuccessMessage"] is string success)
    {
        <div class="alert alert-success" role="status">@success</div>
    }
    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

    <ul class="nav nav-tabs" role="tablist">
        <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#incoming" type="button">Recent Movements</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#create" type="button">Create Transaction</button></li>
    </ul>
    <div class="tab-content inventory-tabs">
        <div class="tab-pane fade show active" id="incoming">
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead><tr><th>Date</th><th>Product</th><th>Type</th><th>Change</th><th>Stock After</th><th></th></tr></thead>
                    <tbody>
                        @if (!Model.Transactions.Any())
                        {
                            <tr><td colspan="6" class="text-center text-muted">No inventory movements yet.</td></tr>
                        }
                        else
                        {
                            @foreach (var transaction in Model.Transactions)
                            {
                                <tr>
                                    <td>@transaction.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                    <td>@transaction.ProductName</td>
                                    <td><span class="badge text-bg-info">@transaction.TransactionType</span></td>
                                    <td>@(transaction.QuantityChange > 0 ? "+" : string.Empty)@transaction.QuantityChange</td>
                                    <td>@transaction.StockAfter</td>
                                    <td><a class="btn btn-sm btn-outline-primary" asp-controller="Warehouse" asp-action="InventoryDetails" asp-route-id="@transaction.ProductId">View Details</a></td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="tab-pane fade" id="create">
            <form class="receipt-form" method="post" asp-controller="Warehouse" asp-action="InventoryManagement">
                @Html.AntiForgeryToken()
                <div class="row g-3">
                    <div class="col-md-5">
                        <label class="form-label" for="ProductId">Product</label>
                        <select class="form-select" id="ProductId" name="ProductId" required>
                            <option value="">Select product</option>
                            @foreach (var product in Model.Products)
                            {
                                <option value="@product.ProductId" selected="@(product.ProductId == Model.Transaction.ProductId)">@product.ProductCode - @product.ProductName (@product.QuantityInStock)</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label" for="TransactionType">Transaction Type</label>
                        <select class="form-select" id="TransactionType" name="TransactionType" required>
                            <option value="Receipt" selected="@(Model.Transaction.TransactionType == "Receipt")">Receipt</option>
                            <option value="Issue" selected="@(Model.Transaction.TransactionType == "Issue")">Issue</option>
                            <option value="Adjustment" selected="@(Model.Transaction.TransactionType == "Adjustment")">Adjustment</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label" for="Quantity">Quantity</label>
                        <input class="form-control" id="Quantity" name="Quantity" type="number" min="1" value="@Model.Transaction.Quantity" required />
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <button class="btn btn-success w-100" type="submit">Save</button>
                    </div>
                    <div class="col-12">
                        <label class="form-label" for="Reason">Reason</label>
                        <textarea class="form-control" id="Reason" name="Reason" rows="3">@Model.Transaction.Reason</textarea>
                    </div>
                </div>
            </form>
        </div>
    </div>
</section>
