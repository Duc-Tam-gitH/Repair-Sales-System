@{
    Layout = "_Layout";
    ViewData["Title"] = "Inventory Management";
    ViewData["ActiveRole"] = "Warehouse";
    ViewData["RoleDisplay"] = "Warehouse Staff";
}

@section Styles {
    <link rel="stylesheet" href="~/css/InventoryManagement.css" asp-append-version="true" />
}

<!-- Data fetched and saved via IWarehouseService.ManageIncomingGoods() -->
<section class="inventory-management-page">
    <div class="inventory-header"><h1>Inventory Management - Incoming Goods</h1><p>Review incoming receipts and create new receipts that update inventory.</p></div>
    <div class="alert alert-success" role="status">Incoming goods receipt confirmed successfully! Inventory updated automatically!</div>

    <ul class="nav nav-tabs" role="tablist">
        <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#incoming" type="button">Incoming Goods List</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#create" type="button">Create Receipt</button></li>
    </ul>
    <div class="tab-content inventory-tabs">
        <div class="tab-pane fade show active" id="incoming">
            <div class="table-responsive"><table class="table align-middle"><thead><tr><th>Receipt Code</th><th>Supplier</th><th>Date Received</th><th>Status</th><th></th></tr></thead><tbody><tr><td>REC-2026-001</td><td>TechParts Co.</td><td>2026-07-18</td><td><span class="badge text-bg-warning">Pending</span></td><td><a class="btn btn-sm btn-outline-primary" asp-controller="Warehouse" asp-action="InventoryDetails">View Details</a></td></tr><tr><td>REC-2026-0009</td><td>Mobile Supply Ltd.</td><td>2026-07-15</td><td><span class="badge text-bg-success">Confirmed</span></td><td><a class="btn btn-sm btn-outline-primary" asp-controller="Warehouse" asp-action="InventoryDetails">View Details</a></td></tr></tbody></table></div>
        </div>
        <div class="tab-pane fade" id="create">
            <form class="receipt-form">
                <div class="row g-3"><div class="col-md-4"><label class="form-label">Select Supplier</label><select class="form-select"><option>TechParts Co.</option><option>Mobile Supply Ltd.</option><option>Hardware Hub</option></select></div><div class="col-md-4"><label class="form-label">Add Product</label><input class="form-control" value="Dell Keyboard Module" /></div><div class="col-md-2"><label class="form-label">Quantity</label><input class="form-control" type="number" value="10" /></div><div class="col-md-2"><label class="form-label">Unit Price</label><input class="form-control" type="number" value="45" /></div></div>
                <div class="table-responsive mt-4"><table class="table align-middle"><thead><tr><th>Item Name</th><th>Quantity</th><th>Unit Price</th><th>Subtotal</th></tr></thead><tbody><tr><td>Dell Keyboard Module</td><td>10</td><td>$45</td><td>$450</td></tr><tr><td>Nova X Battery</td><td>20</td><td>$22</td><td>$440</td></tr></tbody></table></div>
                <div class="d-flex gap-2"><button class="btn btn-outline-primary" type="button">Add More Items</button><button class="btn btn-success" type="button">Confirm Incoming Goods Receipt</button></div>
            </form>
        </div>
    </div>
</section>
