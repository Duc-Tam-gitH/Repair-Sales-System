@model ProductListResponse
@{
    Layout = "_Layout";
    ViewData["Title"] = "Stock List";
    ViewData["ActiveRole"] = "Warehouse";
    ViewData["RoleDisplay"] = "Warehouse Staff";
    var keyword = ViewData["Keyword"] as string;
}

@section Styles {
    <link rel="stylesheet" href="~/css/StockList.css" asp-append-version="true" />
}

<section class="stock-list-page">
    <div class="stock-header">
        <div><h1>Stock List</h1><p>Products and repair components currently tracked in warehouse inventory.</p></div>
        <a class="btn btn-primary" asp-controller="Warehouse" asp-action="InventoryManagement">Incoming Goods</a>
    </div>
    <form class="stock-tools" method="get" asp-controller="Warehouse" asp-action="StockList">
        <input class="form-control" type="search" name="keyword" value="@keyword" placeholder="Search by item name or code..." />
        <button class="btn btn-outline-primary" type="submit">Search</button>
    </form>
    <div class="stock-table table-responsive">
        <table class="table align-middle">
            <thead><tr><th>Item Code</th><th>Item Name</th><th>Category</th><th>Quantity in Stock</th><th>Status</th><th>Actions</th></tr></thead>
            <tbody>
                @if (!Model.Products.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted">@Model.Message</td></tr>
                }
                else
                {
                    @foreach (var product in Model.Products)
                    {
                        var statusClass = product.QuantityInStock <= 0 ? "text-bg-danger" : product.QuantityInStock <= 5 ? "text-bg-warning" : "text-bg-success";
                        var statusText = product.QuantityInStock <= 0 ? "Out of Stock" : product.QuantityInStock <= 5 ? "Low Stock" : "In Stock";
                        <tr>
                            <td>@product.ProductCode</td>
                            <td>@product.ProductName</td>
                            <td>@(product.CategoryName ?? "Uncategorized")</td>
                            <td>@product.QuantityInStock</td>
                            <td><span class="badge @statusClass">@statusText</span></td>
                            <td><a class="btn btn-sm btn-outline-primary" asp-controller="Warehouse" asp-action="InventoryDetails" asp-route-id="@product.ProductId">View Details</a></td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</section>
