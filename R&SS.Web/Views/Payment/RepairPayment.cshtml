@model RepairPaymentViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Repair Payment";
    ViewData["ActiveRole"] = "Payment";
    ViewData["RoleDisplay"] = "Payment Staff";
}

@section Styles {
    <link rel="stylesheet" href="~/css/RepairPayment.css" asp-append-version="true" />
}

<section class="repair-payment-page">
    <div class="repair-payment-header">
        <span>Repair Payment Processing</span>
        <h1>Completed Repair Payments</h1>
        <p>Review completed repair tickets and print invoices for completed payment records.</p>
    </div>

    <section class="step-card">
        <h2>Completed Repair Tickets</h2>
        <table class="table align-middle">
            <thead><tr><th>Repair Code</th><th>Customer</th><th>Device</th><th>Status</th><th>Total</th><th>Completed</th></tr></thead>
            <tbody>
                @if (!Model.CompletedRepairs.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted">No completed repair tickets found.</td></tr>
                }
                else
                {
                    @foreach (var repair in Model.CompletedRepairs)
                    {
                        <tr><td>@repair.RepairOrderCode</td><td>@(repair.Customer?.FullName ?? "Customer")</td><td>@repair.DeviceType</td><td>@repair.Status</td><td>@repair.TotalAmount.ToString("C")</td><td>@(repair.CompletedDate?.ToString("yyyy-MM-dd") ?? "-")</td></tr>
                    }
                }
            </tbody>
        </table>
        <div class="d-flex flex-wrap gap-2 mt-4">
            <a class="btn btn-outline-secondary" asp-controller="Payment" asp-action="TransactionList">Back to Transactions</a>
        </div>
    </section>
</section>
