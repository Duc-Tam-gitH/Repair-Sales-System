@model RepairPaymentViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Repair Payment";
    ViewData["ActiveRole"] = "Payment";
    ViewData["RoleDisplay"] = "Payment Staff";
}

@section Styles {
    <link rel="stylesheet" href="~/css/RepairPayment.css" asp-append-version="true" />
}

<section class="repair-payment-page">
    <div class="repair-payment-header">
        <span>Xử lý thanh toán sửa chữa</span>
        <h1>Thanh toán sửa chữa đã hoàn tất</h1>
        <p>Xem các phiếu sửa chữa đã hoàn tất và in hóa đơn cho các bản ghi thanh toán hoàn tất.</p>
    </div>

    <section class="step-card">
        <h2>Phiếu sửa chữa đã hoàn tất</h2>
        <table class="table align-middle">
            <thead><tr><th>Mã sửa chữa</th><th>Khách hàng</th><th>Thiết bị</th><th>Trạng thái</th><th>Tổng tiền</th><th>Ngày hoàn tất</th></tr></thead>
            <tbody>
                @if (!Model.CompletedRepairs.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted">Không tìm thấy phiếu sửa chữa đã hoàn tất.</td></tr>
                }
                else
                {
                    @foreach (var repair in Model.CompletedRepairs)
                    {
                        <tr><td>@repair.RepairOrderCode</td><td>@(repair.Customer?.FullName ?? "Customer")</td><td>@repair.DeviceType</td><td>@repair.Status</td><td>@repair.TotalAmount.ToString("C")</td><td>@(repair.CompletedDate?.ToString("yyyy-MM-dd") ?? "-")</td></tr>
                    }
                }
            </tbody>
        </table>
        <div class="d-flex flex-wrap gap-2 mt-4">
            <a class="btn btn-outline-secondary" asp-controller="Payment" asp-action="TransactionList">Quay lại giao dịch</a>
        </div>
    </section>
</section>
