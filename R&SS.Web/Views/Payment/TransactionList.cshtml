@model PaymentListViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Transaction List";
    ViewData["ActiveRole"] = "Payment";
    ViewData["RoleDisplay"] = "Payment Staff";
}

@section Styles {
    <link rel="stylesheet" href="~/css/TransactionList.css" asp-append-version="true" />
}

<section class="transaction-list-page">
    <div class="payment-hero">
        <div><span>Payment Management</span><h1>Transaction List</h1><p>Track order payments, repair payments, payment methods, status, and revenue activity.</p></div>
        <a class="btn btn-light" asp-controller="Payment" asp-action="RepairPayment">Repair Payments</a>
    </div>

    @if (TempData["ErrorMessage"] is string error)
    {
        <div class="alert alert-danger" role="alert">@error</div>
    }
    <div class="row g-4">
        <div class="col-md-4"><article class="summary-card"><span>Total Transactions</span><strong>@Model.Payments.Count</strong><small>All records</small></article></div>
        <div class="col-md-4"><article class="summary-card revenue"><span>Total Revenue</span><strong>@Model.Payments.Where(payment => payment.PaymentStatus == "Completed").Sum(payment => payment.Amount).ToString("C")</strong><small>Completed payments</small></article></div>
        <div class="col-md-4"><article class="summary-card pending"><span>Pending Payments</span><strong>@Model.Payments.Count(payment => payment.PaymentStatus.Contains("Pending", StringComparison.OrdinalIgnoreCase))</strong><small>Awaiting confirmation</small></article></div>
    </div>

    <form class="transaction-tools" method="get" asp-controller="Payment" asp-action="TransactionList">
        <input class="form-control" name="keyword" value="@Model.Keyword" placeholder="Search by Transaction ID or Customer Name..." />
        <select class="form-select" name="status"><option value="">All Status</option><option value="Pending">Pending</option><option value="Completed">Completed</option><option value="Failed">Failed</option><option value="Refunded">Refunded</option></select>
        <button class="btn btn-outline-primary" type="submit">Filter</button>
    </form>

    <div class="table-card table-responsive">
        <table class="table align-middle">
            <thead><tr><th>Transaction ID</th><th>Customer Name</th><th>Transaction Type</th><th>Amount</th><th>Payment Method</th><th>Status</th><th>Date</th><th></th></tr></thead>
            <tbody>
                @if (!Model.Payments.Any())
                {
                    <tr><td colspan="8" class="text-center text-muted">No transactions found.</td></tr>
                }
                else
                {
                    @foreach (var payment in Model.Payments)
                    {
                        <tr><td>@payment.PaymentCode</td><td>@(payment.Customer?.FullName ?? "Customer")</td><td>@(payment.SalesOrderId.HasValue ? "Order Payment" : "Repair Payment")</td><td>@payment.Amount.ToString("C")</td><td>@payment.PaymentMethod</td><td><span class="badge text-bg-info">@payment.PaymentStatus</span></td><td>@payment.PaymentDate.ToLocalTime().ToString("yyyy-MM-dd")</td><td><a class="btn btn-sm btn-outline-primary" asp-controller="Payment" asp-action="TransactionDetails" asp-route-id="@payment.PaymentId">View Details</a></td></tr>
                    }
                }
            </tbody>
        </table>
    </div>
</section>
