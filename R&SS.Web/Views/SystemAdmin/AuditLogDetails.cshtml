@model SystemActivityLogResponse
@{
    Layout = "_Layout";
    ViewData["Title"] = "Chi tiết nhật ký kiểm toán";
    ViewData["ActiveRole"] = "SystemAdmin";
    ViewData["RoleDisplay"] = "Quản trị hệ thống";
}

@section Styles {
    <link rel="stylesheet" href="~/css/AuditLogDetails.css" asp-append-version="true" />
}

<section class="audit-details-page">
    <div class="details-hero">
        <div><span>Mã nhật ký</span><h1>LOG-@Model.SystemActivityLogId</h1><p>Ngày & giờ: @Model.ExecutedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</p></div>
        <a class="btn btn-light" asp-controller="SystemAdmin" asp-action="AuditLog">Quay lại nhật ký</a>
    </div>

    <div class="row g-4">
        <div class="col-lg-4"><section class="detail-card"><h2>Thông tin người dùng</h2><p><strong>Tên người dùng:</strong> @(Model.ActorUsername ?? "System")</p><p><strong>Mã người dùng:</strong> @(Model.ActorUserId?.ToString() ?? "-")</p><p><strong>Kết quả:</strong> @Model.ExecutionResult</p></section></div>
        <div class="col-lg-8"><section class="detail-card"><h2>Thông tin hoạt động</h2><p><strong>Loại hoạt động:</strong> @Model.OperationType</p><p><strong>Phân hệ:</strong> @Model.FunctionName</p><p><strong>Dữ liệu bị ảnh hưởng:</strong> @(Model.AffectedData ?? "-")</p><p><strong>Mô tả:</strong> @(Model.Details ?? "-")</p></section></div>
    </div>
</section>
