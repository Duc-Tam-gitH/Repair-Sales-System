@model SystemActivityLogResponse
@{
    Layout = "_Layout";
    ViewData["Title"] = "Audit Log Details";
    ViewData["ActiveRole"] = "SystemAdmin";
    ViewData["RoleDisplay"] = "System Administrator";
}

@section Styles {
    <link rel="stylesheet" href="~/css/AuditLogDetails.css" asp-append-version="true" />
}

<section class="audit-details-page">
    <div class="details-hero">
        <div><span>Log ID</span><h1>LOG-@Model.SystemActivityLogId</h1><p>Date & Time: @Model.ExecutedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</p></div>
        <a class="btn btn-light" asp-controller="SystemAdmin" asp-action="AuditLog">Back to Logs</a>
    </div>

    <div class="row g-4">
        <div class="col-lg-4"><section class="detail-card"><h2>User Information</h2><p><strong>User Name:</strong> @(Model.ActorUsername ?? "System")</p><p><strong>User ID:</strong> @(Model.ActorUserId?.ToString() ?? "-")</p><p><strong>Result:</strong> @Model.ExecutionResult</p></section></div>
        <div class="col-lg-8"><section class="detail-card"><h2>Activity Information</h2><p><strong>Activity Type:</strong> @Model.OperationType</p><p><strong>Module:</strong> @Model.FunctionName</p><p><strong>Affected Data:</strong> @(Model.AffectedData ?? "-")</p><p><strong>Description:</strong> @(Model.Details ?? "-")</p></section></div>
    </div>
</section>
