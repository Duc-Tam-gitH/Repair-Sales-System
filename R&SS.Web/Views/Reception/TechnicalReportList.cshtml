@model TechnicalTicketListResponse
@{
    Layout = "_Layout";
    ViewData["Title"] = "Technical Reports";
    ViewData["ActiveRole"] = "Reception";
    ViewData["RoleDisplay"] = "Reception Staff";
}

@section Styles {
    <link rel="stylesheet" href="~/css/TechnicalReportList.css" asp-append-version="true" />
}

<section class="technical-report-list-page">
    <div class="report-list-header">
        <h1>Technical Report List</h1>
        <a class="btn btn-primary" asp-controller="Reception" asp-action="EquipmentReception">New Technical Report</a>
    </div>
    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="alert alert-danger" role="alert">@errorMessage</div>
    }
    <div class="table-card table-responsive">
        <table class="table align-middle">
            <thead><tr><th>Report Code</th><th>Customer Name</th><th>Equipment</th><th>Status</th><th>Technician</th><th>Actions</th></tr></thead>
            <tbody>
                @if (!Model.Tickets.Any())
                {
                    <tr><td colspan="6">@Model.Message</td></tr>
                }
                else
                {
                    @foreach (var ticket in Model.Tickets)
                    {
                        <tr>
                            <td>@ticket.TicketCode</td>
                            <td>@ticket.CustomerName</td>
                            <td>@ticket.Brand @ticket.DeviceModel - @ticket.DeviceType</td>
                            <td><span class="badge text-bg-info">@ticket.Status</span></td>
                            <td>@(ticket.AssignedTechnicianName ?? "Unassigned")</td>
                            <td><a class="btn btn-sm btn-outline-primary" asp-controller="Reception" asp-action="TechnicalReportDetails" asp-route-id="@ticket.RepairOrderId">View Details</a></td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</section>
