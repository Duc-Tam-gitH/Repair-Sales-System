@model IReadOnlyCollection<ServiceRequestResponse>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Online Repair Requests";
    ViewData["ActiveRole"] = "Reception";
    ViewData["RoleDisplay"] = "Reception Staff";
}

@section Styles {
    <link rel="stylesheet" href="~/css/RepairRequestList.css" asp-append-version="true" />
}

<section class="repair-request-page">
    <div class="request-header">
        <h1>Online Repair Request List</h1>
        <a class="btn btn-primary" asp-controller="Reception" asp-action="EquipmentReception">Create Intake</a>
    </div>
    <form class="request-tools" method="get" asp-controller="Reception" asp-action="RepairRequestList">
        <input class="form-control" name="keyword" value="@ViewData["Keyword"]" type="search" placeholder="Search request or device..." />
        <button class="btn btn-outline-primary" type="submit">Search</button>
    </form>
    <div class="table-card table-responsive">
        <table class="table align-middle">
            <thead><tr><th>Request ID</th><th>Service Type</th><th>Device Type</th><th>Fault Description</th><th>Status</th><th>Actions</th></tr></thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="6">No pending online repair requests found.</td></tr>
                }
                else
                {
                    @foreach (var request in Model)
                    {
                        <tr>
                            <td>@request.RequestCode</td>
                            <td>@request.ServiceType</td>
                            <td>@request.Brand @request.DeviceModel - @request.DeviceType</td>
                            <td>@request.Description</td>
                            <td><span class="badge text-bg-warning">@request.Status</span></td>
                            <td><a class="btn btn-sm btn-success" asp-controller="Reception" asp-action="EquipmentReception" asp-route-requestId="@request.ServiceRequestId">Accept Request</a></td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</section>
