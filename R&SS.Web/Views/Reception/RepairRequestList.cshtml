@model IReadOnlyCollection<ServiceRequestResponse>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Yêu cầu sửa chữa trực tuyến";
    ViewData["ActiveRole"] = "Reception";
    ViewData["RoleDisplay"] = "Nhân viên tiếp nhận";
}

@section Styles {
    <link rel="stylesheet" href="~/css/RepairRequestList.css" asp-append-version="true" />
}

<section class="repair-request-page">
    <div class="request-header">
        <h1>Danh sách yêu cầu sửa chữa trực tuyến</h1>
        <a class="btn btn-primary" asp-controller="Reception" asp-action="EquipmentReception">Tạo phiếu tiếp nhận</a>
    </div>
    <form class="request-tools" method="get" asp-controller="Reception" asp-action="RepairRequestList">
        <input class="form-control" name="keyword" value="@ViewData["Keyword"]" type="search" placeholder="Tìm yêu cầu hoặc thiết bị..." />
        <button class="btn btn-outline-primary" type="submit">Tìm kiếm</button>
    </form>
    <div class="table-card table-responsive">
        <table class="table align-middle">
            <thead><tr><th>Mã yêu cầu</th><th>Loại dịch vụ</th><th>Loại thiết bị</th><th>Mô tả lỗi</th><th>Trạng thái</th><th>Thao tác</th></tr></thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="6">Không tìm thấy yêu cầu sửa chữa trực tuyến đang chờ.</td></tr>
                }
                else
                {
                    @foreach (var request in Model)
                    {
                        <tr>
                            <td>@request.RequestCode</td>
                            <td>@request.ServiceType</td>
                            <td>@request.Brand @request.DeviceModel - @request.DeviceType</td>
                            <td>@request.Description</td>
                            <td><span class="badge text-bg-warning">@request.Status</span></td>
                            <td><a class="btn btn-sm btn-success" asp-controller="Reception" asp-action="EquipmentReception" asp-route-requestId="@request.ServiceRequestId">Tiếp nhận yêu cầu</a></td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</section>
