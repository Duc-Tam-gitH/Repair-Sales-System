@model ReceptionIntakeViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Equipment Reception";
    ViewData["ActiveRole"] = "Reception";
    ViewData["RoleDisplay"] = "Reception Staff";
}

@section Styles {
    <link rel="stylesheet" href="~/css/EquipmentReception.css" asp-append-version="true" />
}

<section class="equipment-reception-page">
    <div class="step-banner">
        <span>Technical Intake</span>
        <h1>Equipment Reception</h1>
        <p>Select the customer, record the device condition, and create the technical ticket.</p>
    </div>

    @if (Model.SourceRequest is not null)
    {
        <div class="alert alert-info" role="status">Loaded online request @Model.SourceRequest.RequestCode.</div>
    }
    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

    <form class="intake-form" method="post" asp-controller="Reception" asp-action="EquipmentReception">
        @Html.AntiForgeryToken()
        <section class="form-section">
            <h2>Select Customer</h2>
            <div class="row g-3">
                <div class="col-md-8">
                    <label class="form-label" for="CustomerId">Existing Customer</label>
                    <select class="form-select" id="CustomerId" name="CustomerId" required>
                        @foreach (var customer in Model.Customers)
                        {
                            <option value="@customer.CustomerId" selected="@(customer.CustomerId == Model.Ticket.CustomerId)">@customer.FullName - @customer.CustomerCode</option>
                        }
                    </select>
                </div>
                <div class="col-md-4 d-flex align-items-end"><a class="btn btn-outline-primary w-100" asp-controller="Reception" asp-action="AddCustomer">Add New Customer</a></div>
            </div>
        </section>

        <section class="form-section">
            <h2>Equipment Information</h2>
            <div class="row g-3">
                <div class="col-md-4"><label class="form-label" for="DeviceName">Equipment Name</label><input class="form-control" id="DeviceName" name="DeviceName" value="@Model.Ticket.DeviceName" placeholder="Dell Inspiron 15" /></div>
                <div class="col-md-4"><label class="form-label" for="DeviceType">Equipment Type</label><input class="form-control" id="DeviceType" name="DeviceType" value="@Model.Ticket.DeviceType" required /></div>
                <div class="col-md-4"><label class="form-label" for="Brand">Brand</label><input class="form-control" id="Brand" name="Brand" value="@Model.Ticket.Brand" required /></div>
                <div class="col-md-6"><label class="form-label" for="DeviceModel">Model</label><input class="form-control" id="DeviceModel" name="DeviceModel" value="@Model.Ticket.DeviceModel" /></div>
                <div class="col-md-6"><label class="form-label" for="SerialNumber">Serial Number</label><input class="form-control" id="SerialNumber" name="SerialNumber" value="@Model.Ticket.SerialNumber" /></div>
                <div class="col-md-6"><label class="form-label" for="CustomerEmail">Customer Email</label><input class="form-control" id="CustomerEmail" name="CustomerEmail" value="@Model.Ticket.CustomerEmail" type="email" required /></div>
                <div class="col-md-6"><label class="form-label" for="CustomerPhone">Customer Phone</label><input class="form-control" id="CustomerPhone" name="CustomerPhone" value="@Model.Ticket.CustomerPhone" required /></div>
                <div class="col-md-6"><label class="form-label" for="RequestType">Request Type</label><input class="form-control" id="RequestType" name="RequestType" value="@Model.Ticket.RequestType" required /></div>
                <div class="col-md-6"><label class="form-label" for="DeviceCondition">Equipment Status</label><input class="form-control" id="DeviceCondition" name="DeviceCondition" value="@Model.Ticket.DeviceCondition" placeholder="Good, scratched, broken..." required /></div>
                <div class="col-12"><label class="form-label" for="IssueDescription">Initial Fault Description</label><textarea class="form-control" id="IssueDescription" name="IssueDescription" rows="4" required>@Model.Ticket.IssueDescription</textarea></div>
                <div class="col-12"><label class="form-label" for="Notes">Included Accessories / Notes</label><textarea class="form-control" id="Notes" name="Notes" rows="3">@Model.Ticket.Notes</textarea></div>
            </div>
            <button class="btn btn-primary mt-4" type="submit">Create Technical Ticket</button>
        </section>
    </form>
</section>
