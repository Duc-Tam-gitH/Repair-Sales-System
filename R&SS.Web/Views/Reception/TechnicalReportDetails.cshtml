@model TechnicalTicketResponse
@{
    Layout = "_Layout";
    ViewData["Title"] = "Chi tiết báo cáo kỹ thuật";
    ViewData["ActiveRole"] = "Reception";
    ViewData["RoleDisplay"] = "Nhân viên tiếp nhận";
}

@section Styles {
    <link rel="stylesheet" href="~/css/TechnicalReportDetails.css" asp-append-version="true" />
}

<section class="technical-details-page">
    <div class="details-hero">
        <div><span>@Model.TicketCode</span><h1>Chi tiết báo cáo kỹ thuật</h1><p>Trạng thái: @Model.Status</p></div>
        <a class="btn btn-light" asp-controller="Reception" asp-action="TechnicalReportList">Quay lại báo cáo</a>
    </div>

    <div class="row g-4">
        <div class="col-lg-4"><section class="detail-box"><h2>Thông tin khách hàng</h2><p><strong>Tên:</strong> @Model.CustomerName</p><p><strong>Điện thoại:</strong> @Model.CustomerPhone</p><p><strong>Email:</strong> @Model.CustomerEmail</p></section></div>
        <div class="col-lg-4"><section class="detail-box"><h2>Thông tin thiết bị</h2><p><strong>Thiết bị:</strong> @Model.Brand @Model.DeviceModel</p><p><strong>Loại:</strong> @Model.DeviceType</p><p><strong>Trạng thái:</strong> @Model.DeviceCondition</p><p><strong>Lỗi:</strong> @Model.IssueDescription</p></section></div>
        <div class="col-lg-4"><section class="detail-box"><h2>Phân công</h2><p><strong>Kỹ thuật viên:</strong> @(Model.AssignedTechnicianName ?? "Chưa phân công")</p><p><strong>Loại yêu cầu:</strong> @Model.RequestType</p><p><strong>Hạn bàn giao:</strong> @Model.DeliveryConfirmationDeadlineUtc?.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</p></section></div>
    </div>
</section>
