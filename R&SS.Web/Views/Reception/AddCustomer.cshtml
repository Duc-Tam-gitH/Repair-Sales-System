@model CreateCustomerRequest
@{
    Layout = "_Layout";
    ViewData["Title"] = "Add Customer";
    ViewData["ActiveRole"] = "Reception";
    ViewData["RoleDisplay"] = "Reception Staff";
}

@section Styles {
    <link rel="stylesheet" href="~/css/AddCustomer.css" asp-append-version="true" />
}

<section class="add-customer-page">
    <div class="form-shell">
        <div class="form-heading">
            <span>Customer Profile</span>
            <h1>Add Customer</h1>
            <p>Create a new customer profile for intake, orders, and repair reports.</p>
        </div>

        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
        <form method="post" asp-controller="Reception" asp-action="AddCustomer">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-6"><label class="form-label" asp-for="CustomerCode">Customer Code</label><input class="form-control" asp-for="CustomerCode" placeholder="CUS-004" required /></div>
                <div class="col-md-6"><label class="form-label" asp-for="FullName">Full Name</label><input class="form-control" asp-for="FullName" placeholder="Customer full name" required /></div>
                <div class="col-md-6"><label class="form-label" asp-for="Phone">Phone Number</label><input class="form-control" asp-for="Phone" placeholder="Phone number" /></div>
                <div class="col-md-6"><label class="form-label" asp-for="Email">Email Address</label><input class="form-control" asp-for="Email" type="email" placeholder="Email address" /></div>
                <div class="col-12"><label class="form-label" asp-for="Address">Address</label><textarea class="form-control" asp-for="Address" rows="3"></textarea></div>
                <div class="col-12"><label class="form-label" asp-for="Notes">Notes</label><textarea class="form-control" asp-for="Notes" rows="3"></textarea></div>
            </div>
            <div class="d-flex gap-2 mt-4">
                <button class="btn btn-primary" type="submit">Save Customer</button>
                <a class="btn btn-outline-secondary" asp-controller="Reception" asp-action="CustomerList">Cancel</a>
            </div>
        </form>
    </div>
</section>
