@{
    Layout = "_Layout";
    ViewData["Title"] = "Customer List";
    ViewData["ActiveRole"] = "Reception";
    ViewData["RoleDisplay"] = "Reception Staff";
}

@section Styles {
    <link rel="stylesheet" href="~/css/CustomerList.css" asp-append-version="true" />
}

<!-- Data fetched via IReceptionService.GetCustomers() -->
<section class="customer-list-page">
    <div class="list-header">
        <div><h1>Customer List</h1><p>Search, review, add, edit, or deactivate customer profiles.</p></div>
        <a class="btn btn-primary" asp-controller="Reception" asp-action="AddCustomer">Add Customer</a>
    </div>

    <div class="alert alert-warning" role="alert">Deactivate action requires confirmation before updating customer status.</div>
    <div class="list-tools">
        <input class="form-control" type="search" placeholder="Search by name or phone..." />
        <select class="form-select"><option>All</option><option>Active</option><option>Inactive</option></select>
    </div>

    <div class="table-card table-responsive">
        <table class="table align-middle">
            <thead><tr><th>Customer Code</th><th>Full Name</th><th>Phone Number</th><th>Email</th><th>Status</th><th>Actions</th></tr></thead>
            <tbody>
                <tr><td>CUS-001</td><td>Minh Tran</td><td>0901112222</td><td>minh@example.com</td><td><span class="badge text-bg-success">Active</span></td><td><a class="btn btn-sm btn-outline-primary" asp-controller="Reception" asp-action="CustomerDetails">View Details</a> <a class="btn btn-sm btn-outline-secondary" asp-controller="Reception" asp-action="CustomerDetails">Edit</a> <button class="btn btn-sm btn-outline-danger">Deactivate</button></td></tr>
                <tr><td>CUS-002</td><td>Anya Pham</td><td>0903334444</td><td>anya@example.com</td><td><span class="badge text-bg-success">Active</span></td><td><a class="btn btn-sm btn-outline-primary" asp-controller="Reception" asp-action="CustomerDetails">View Details</a> <a class="btn btn-sm btn-outline-secondary" asp-controller="Reception" asp-action="CustomerDetails">Edit</a> <button class="btn btn-sm btn-outline-danger">Deactivate</button></td></tr>
                <tr><td>CUS-003</td><td>David Lee</td><td>0905556666</td><td>david@example.com</td><td><span class="badge text-bg-secondary">Inactive</span></td><td><a class="btn btn-sm btn-outline-primary" asp-controller="Reception" asp-action="CustomerDetails">View Details</a> <a class="btn btn-sm btn-outline-secondary" asp-controller="Reception" asp-action="CustomerDetails">Edit</a></td></tr>
            </tbody>
        </table>
    </div>
</section>
