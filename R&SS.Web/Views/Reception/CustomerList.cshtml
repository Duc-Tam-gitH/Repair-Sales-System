@model CustomerListResponse
@{
    Layout = "_Layout";
    ViewData["Title"] = "Customer List";
    ViewData["ActiveRole"] = "Reception";
    ViewData["RoleDisplay"] = "Reception Staff";
}

@section Styles {
    <link rel="stylesheet" href="~/css/CustomerList.css" asp-append-version="true" />
}

<section class="customer-list-page">
    <div class="list-header">
        <div><h1>Customer List</h1><p>Search, review, add, edit, or deactivate customer profiles.</p></div>
        <a class="btn btn-primary" asp-controller="Reception" asp-action="AddCustomer">Add Customer</a>
    </div>

    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="alert alert-danger" role="alert">@errorMessage</div>
    }
    <form class="list-tools" method="get" asp-controller="Reception" asp-action="CustomerList">
        <input class="form-control" name="keyword" value="@ViewData["Keyword"]" type="search" placeholder="Search by name or phone..." />
        <button class="btn btn-outline-primary" type="submit">Search</button>
    </form>

    <div class="table-card table-responsive">
        <table class="table align-middle">
            <thead><tr><th>Customer Code</th><th>Full Name</th><th>Phone Number</th><th>Email</th><th>Status</th><th>Actions</th></tr></thead>
            <tbody>
                @if (!Model.Customers.Any())
                {
                    <tr><td colspan="6">@Model.Message</td></tr>
                }
                else
                {
                    @foreach (var customer in Model.Customers)
                    {
                        <tr>
                            <td>@customer.CustomerCode</td>
                            <td>@customer.FullName</td>
                            <td>@customer.Phone</td>
                            <td>@customer.Email</td>
                            <td><span class="badge @(customer.IsActive ? "text-bg-success" : "text-bg-secondary")">@(customer.IsActive ? "Active" : "Inactive")</span></td>
                            <td><a class="btn btn-sm btn-outline-primary" asp-controller="Reception" asp-action="CustomerDetails" asp-route-id="@customer.CustomerId">View Details</a></td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</section>
