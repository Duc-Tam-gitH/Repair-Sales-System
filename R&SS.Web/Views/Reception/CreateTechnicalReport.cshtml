@{
    Layout = "_Layout";
    ViewData["Title"] = "Tạo báo cáo kỹ thuật";
    ViewData["ActiveRole"] = "Reception";
    ViewData["RoleDisplay"] = "Nhân viên tiếp nhận";
}

@section Styles {
    <link rel="stylesheet" href="~/css/CreateTechnicalReport.css" asp-append-version="true" />
}

<!-- Data saved via IReportService.CreateTechnicalReport() -->
<section class="technical-report-page">
    <div class="report-header">
        <div><span>Bước 2</span><h1>Tạo báo cáo kỹ thuật</h1><p>Xác nhận thông tin tiếp nhận, phân công kỹ thuật viên và lưu báo cáo.</p></div>
        <strong>#TECH-2026-001</strong>
    </div>

    <div class="alert alert-success" role="status">Đã lưu báo cáo! Đây là thông báo mẫu của giao diện tĩnh.</div>
    <form class="report-form">
        <div class="row g-4">
            <div class="col-lg-6">
                <section class="report-section">
                    <h2>Thông tin khách hàng</h2>
                    <label class="form-label" for="customerName">Khách hàng</label><input class="form-control" id="customerName" value="Minh Tran - 0901112222" />
                    <label class="form-label mt-3" for="customerAddress">Địa chỉ</label><input class="form-control" id="customerAddress" value="45 Nguyen Street, District 1" />
                </section>
            </div>
            <div class="col-lg-6">
                <section class="report-section">
                    <h2>Thông tin thiết bị</h2>
                    <label class="form-label" for="equipment">Thiết bị</label><input class="form-control" id="equipment" value="Dell Inspiron 15 - Laptop" />
                    <label class="form-label mt-3" for="fault">Mô tả lỗi</label><textarea class="form-control" id="fault" rows="2">Bàn phím không hoạt động</textarea>
                </section>
            </div>
            <div class="col-md-4"><label class="form-label" for="receiptDate">Ngày tiếp nhận</label><input class="form-control" id="receiptDate" type="date" value="2026-07-18" /></div>
            <div class="col-md-4"><label class="form-label" for="appointment">Lịch hẹn</label><input class="form-control" id="appointment" type="datetime-local" /></div>
            <div class="col-md-4"><label class="form-label" for="technician">Phân công kỹ thuật viên</label><select class="form-select" id="technician"><option>Huy Nguyen</option><option>Lan Ho</option><option>Son Vo</option></select></div>
        </div>
        <div class="d-flex gap-2 mt-4">
            <a class="btn btn-primary" asp-controller="Reception" asp-action="TechnicalReportList">Lưu báo cáo</a>
            <button class="btn btn-outline-secondary" type="button">Xem trước khi in</button>
        </div>
    </form>
</section>
