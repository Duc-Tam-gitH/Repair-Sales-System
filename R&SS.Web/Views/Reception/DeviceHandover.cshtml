@model IReadOnlyCollection<TechnicalTicketResponse>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Device Handover";
    ViewData["ActiveRole"] = "Reception";
    ViewData["RoleDisplay"] = "Reception Staff";
}

@section Styles {
    <link rel="stylesheet" href="~/css/DeviceHandover.css" asp-append-version="true" />
}

<section class="handover-page">
    <div class="handover-header">
        <h1>Device Handover / Delivery</h1>
        <a class="btn btn-outline-primary" asp-controller="Reception" asp-action="TechnicalReportList">All Reports</a>
    </div>

    <div class="row g-4">
        <div class="col-lg-12">
            <section class="handover-list">
                <h2>Pending Handover</h2>
                @if (!Model.Any())
                {
                    <article><strong>No pending handovers</strong><span>Completed repair tickets will appear here.</span></article>
                }
                else
                {
                    @foreach (var ticket in Model)
                    {
                        <article>
                            <strong>@ticket.TicketCode</strong>
                            <span>@ticket.CustomerName - @ticket.Brand @ticket.DeviceModel</span>
                            <a class="btn btn-sm btn-outline-primary" asp-controller="Reception" asp-action="TechnicalReportDetails" asp-route-id="@ticket.RepairOrderId">View Report Details</a>
                        </article>
                    }
                }
            </section>
        </div>
    </div>
</section>
