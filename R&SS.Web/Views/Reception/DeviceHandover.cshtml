@model IReadOnlyCollection<TechnicalTicketResponse>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Bàn giao thiết bị";
    ViewData["ActiveRole"] = "Reception";
    ViewData["RoleDisplay"] = "Nhân viên tiếp nhận";
}

@section Styles {
    <link rel="stylesheet" href="~/css/DeviceHandover.css" asp-append-version="true" />
}

<section class="handover-page">
    <div class="handover-header">
        <h1>Bàn giao / trả thiết bị</h1>
        <a class="btn btn-outline-primary" asp-controller="Reception" asp-action="TechnicalReportList">Tất cả báo cáo</a>
    </div>

    <div class="row g-4">
        <div class="col-lg-12">
            <section class="handover-list">
                <h2>Chờ bàn giao</h2>
                @if (!Model.Any())
                {
                    <article><strong>Không có phiếu chờ bàn giao</strong><span>Các phiếu sửa chữa đã hoàn tất sẽ hiển thị tại đây.</span></article>
                }
                else
                {
                    @foreach (var ticket in Model)
                    {
                        <article>
                            <strong>@ticket.TicketCode</strong>
                            <span>@ticket.CustomerName - @ticket.Brand @ticket.DeviceModel</span>
                            <a class="btn btn-sm btn-outline-primary" asp-controller="Reception" asp-action="TechnicalReportDetails" asp-route-id="@ticket.RepairOrderId">Xem chi tiết báo cáo</a>
                        </article>
                    }
                }
            </section>
        </div>
    </div>
</section>
