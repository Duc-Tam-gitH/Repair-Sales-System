@model CustomerResponse
@{
    Layout = "_Layout";
    ViewData["Title"] = "Customer Details";
    ViewData["ActiveRole"] = "Reception";
    ViewData["RoleDisplay"] = "Reception Staff";
}

@section Styles {
    <link rel="stylesheet" href="~/css/CustomerDetails.css" asp-append-version="true" />
}

<section class="customer-details-page">
    <div class="profile-panel">
        <div>
            <span>@Model.CustomerCode</span>
            <h1>@Model.FullName</h1>
            <p>@(Model.IsActive ? "Active customer profile" : "Inactive customer profile")</p>
        </div>
        <a class="btn btn-primary" asp-controller="Reception" asp-action="EquipmentReception">Create Intake</a>
    </div>

    <div class="info-grid">
        <div><strong>Phone</strong><p>@Model.Phone</p></div>
        <div><strong>Email</strong><p>@Model.Email</p></div>
        <div><strong>Address</strong><p>@Model.Address</p></div>
        <div><strong>Notes</strong><p>@Model.Notes</p></div>
    </div>
</section>
