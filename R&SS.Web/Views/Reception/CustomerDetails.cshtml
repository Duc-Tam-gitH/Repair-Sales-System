@model CustomerResponse
@{
    Layout = "_Layout";
    ViewData["Title"] = "Chi tiết khách hàng";
    ViewData["ActiveRole"] = "Reception";
    ViewData["RoleDisplay"] = "Nhân viên tiếp nhận";
}

@section Styles {
    <link rel="stylesheet" href="~/css/CustomerDetails.css" asp-append-version="true" />
}

<section class="customer-details-page">
    <div class="profile-panel">
        <div>
            <span>@Model.CustomerCode</span>
            <h1>@Model.FullName</h1>
            <p>@(Model.IsActive ? "Hồ sơ khách hàng đang hoạt động" : "Hồ sơ khách hàng ngừng hoạt động")</p>
        </div>
        <a class="btn btn-primary" asp-controller="Reception" asp-action="EquipmentReception">Tạo phiếu tiếp nhận</a>
    </div>

    <div class="info-grid">
        <div><strong>Điện thoại</strong><p>@Model.Phone</p></div>
        <div><strong>Email</strong><p>@Model.Email</p></div>
        <div><strong>Địa chỉ</strong><p>@Model.Address</p></div>
        <div><strong>Ghi chú</strong><p>@Model.Notes</p></div>
    </div>
</section>
