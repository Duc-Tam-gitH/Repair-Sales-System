@{
    ViewData["Title"] = "Trang tiếp nhận";
    ViewData["ActiveRole"] = "Reception";
    ViewData["RoleDisplay"] = "Đăng nhập với vai trò Tiếp nhận";
}

<section class="rss-role-home rss-reception-home" aria-labelledby="reception-home-title">
    <header class="mb-4">
        <p class="text-muted mb-1">Không gian quầy tiếp nhận</p>
        <h1 id="reception-home-title">Quầy tiếp nhận</h1>
        <p class="text-muted mb-0">Tạo phiếu yêu cầu kỹ thuật, quản lý hồ sơ khách hàng và xử lý hàng đợi tiếp nhận.</p>
    </header>

    <nav class="rss-role-menu mb-4" aria-label="Menu tiếp nhận">
        <a href="#">Phiếu</a>
        <a href="#">Phiếu mới</a>
        <a href="#">Khách hàng</a>
        <a href="#">Hàng đợi dịch vụ</a>
    </nav>

    <div class="row g-3 mb-4">
        <div class="col-md-3"><div class="rss-metric"><span>Phiếu mới hôm nay</span><strong>12</strong></div></div>
        <div class="col-md-3"><div class="rss-metric"><span>Chờ phân công</span><strong>5</strong></div></div>
        <div class="col-md-3"><div class="rss-metric"><span>Cập nhật khách hàng</span><strong>8</strong></div></div>
        <div class="col-md-3"><div class="rss-metric"><span>Chờ xác nhận</span><strong>3</strong></div></div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3"><a class="rss-action rss-action-primary" href="#"><strong>Phiếu mới</strong><span>Tạo phiếu yêu cầu kỹ thuật.</span></a></div>
        <div class="col-md-3"><a class="rss-action" href="#"><strong>Tìm khách hàng</strong><span>Tìm theo điện thoại, email, tên hoặc mã.</span></a></div>
        <div class="col-md-3"><a class="rss-action" href="#"><strong>Đăng ký khách hàng</strong><span>Thêm hồ sơ trước khi tiếp nhận.</span></a></div>
        <div class="col-md-3"><a class="rss-action" href="#"><strong>Hàng đợi dịch vụ</strong><span>Xem các bàn giao đang chờ hôm nay.</span></a></div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <section class="rss-panel" aria-labelledby="intake-title">
                <header><h2 id="intake-title">Hàng đợi tiếp nhận</h2></header>
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead><tr><th>Phiếu</th><th>Khách hàng</th><th>Thiết bị</th><th>Trạng thái</th><th>Thao tác</th></tr></thead>
                        <tbody>
                            <tr><td>TT-1051</td><td>Minh Tran</td><td>Máy tính để bàn</td><td>Chưa phân công</td><td><a href="#">Mở</a></td></tr>
                            <tr><td>TT-1050</td><td>Anya Pham</td><td>Máy in</td><td>Đã tạo</td><td><a href="#">Mở</a></td></tr>
                            <tr><td>TT-1049</td><td>David Lee</td><td>Máy tính bảng</td><td>Cần bổ sung thông tin</td><td><a href="#">Sửa</a></td></tr>
                        </tbody>
                    </table>
                </div>
            </section>
        </div>
        <div class="col-lg-4">
            <section class="rss-panel" aria-labelledby="lookup-title">
                <header><h2 id="lookup-title">Tra cứu khách hàng</h2></header>
                <form>
                    <label class="form-label" for="customerSearch">Tìm khách hàng</label>
                    <input class="form-control" id="customerSearch" type="search" placeholder="Tên, điện thoại, email hoặc mã" />
                </form>
            </section>
        </div>
    </div>
</section>
