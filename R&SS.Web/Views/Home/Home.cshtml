@{
    Layout = "_Layout";
    ViewData["Title"] = "Dashboard";
    ViewData["RoleDisplay"] = "Admin User";
}

<section class="dashboard-mockup" aria-labelledby="dashboard-title">
    <div class="dashboard-grid">
        <article class="dashboard-stat-card">
            <span>Total Orders</span>
            <strong>1,248</strong>
            <small>+18 today</small>
        </article>
        <article class="dashboard-stat-card">
            <span>Revenue</span>
            <strong>$48.9k</strong>
            <small>+12% this month</small>
        </article>
        <article class="dashboard-stat-card">
            <span>Clients</span>
            <strong>642</strong>
            <small>+7 this week</small>
        </article>
        <article class="dashboard-stat-card">
            <span>Pending Repairs</span>
            <strong>86</strong>
            <small>14 urgent</small>
        </article>
    </div>

    <div class="dashboard-panel-grid">
        <section class="dashboard-panel" aria-labelledby="orders-chart-title">
            <h2 id="orders-chart-title">Repair & Order Volume</h2>
            <div class="mock-chart" aria-label="Simulated bar chart">
                <span style="height: 42%"></span>
                <span style="height: 68%"></span>
                <span style="height: 54%"></span>
                <span style="height: 82%"></span>
                <span style="height: 76%"></span>
                <span style="height: 92%"></span>
                <span style="height: 63%"></span>
            </div>
        </section>

        <section class="dashboard-panel" aria-labelledby="activity-title">
            <h2 id="activity-title">Recent Activity</h2>
            <div class="activity-list">
                <div class="activity-item">
                    <strong>Repair ticket TECH-2026-001 updated</strong>
                    <span>Technician moved task to In-Repair.</span>
                </div>
                <div class="activity-item">
                    <strong>Inventory alert</strong>
                    <span>OLED screen assembly reached out-of-stock status.</span>
                </div>
                <div class="activity-item">
                    <strong>Order SO-2026-1042 confirmed</strong>
                    <span>Payment is pending verification.</span>
                </div>
                <div class="activity-item">
                    <strong>New customer registered</strong>
                    <span>Minh Tran added by reception desk.</span>
                </div>
            </div>
        </section>
    </div>
</section>
