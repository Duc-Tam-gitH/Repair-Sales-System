@model TechnicalTicketListResponse
@{
    Layout = "_Layout";
    ViewData["Title"] = "Technician Dashboard";
    ViewData["ActiveRole"] = "Technician";
    ViewData["RoleDisplay"] = "Technician User";
    var pendingCount = Model.Tickets.Count(ticket => ticket.Status.Contains("Pending", StringComparison.OrdinalIgnoreCase));
    var progressCount = Model.Tickets.Count(ticket => !ticket.Status.Contains("Pending", StringComparison.OrdinalIgnoreCase) && !ticket.Status.Equals("Completed", StringComparison.OrdinalIgnoreCase));
}

@section Styles {
    <link rel="stylesheet" href="~/css/TechnicianDashboard.css" asp-append-version="true" />
}

<section class="technician-dashboard-page">
    <div class="tech-hero">
        <div><span>Repair Workbench</span><h1>Technician Dashboard</h1><p>Review assigned work and the next tasks that need technical action.</p></div>
        <a class="btn btn-light" asp-controller="Technician" asp-action="AssignedTasks">Open My Tasks</a>
    </div>

    <div class="row g-4">
        <div class="col-md-6 col-xl-3"><article class="tech-metric"><span>Total Assigned Tasks</span><strong>@Model.Tickets.Count</strong></article></div>
        <div class="col-md-6 col-xl-3"><article class="tech-metric pending"><span>Pending Tasks</span><strong>@pendingCount</strong></article></div>
        <div class="col-md-6 col-xl-3"><article class="tech-metric progress"><span>In-Progress Tasks</span><strong>@progressCount</strong></article></div>
        <div class="col-md-6 col-xl-3"><article class="tech-metric due"><span>Ready to Complete</span><strong>@Model.Tickets.Count(ticket => ticket.Status.Contains("Delivery", StringComparison.OrdinalIgnoreCase))</strong></article></div>
    </div>

    <div class="urgent-panel mt-4 table-responsive">
        <h2>Recent Tasks</h2>
        <table class="table align-middle">
            <thead><tr><th>Task ID</th><th>Customer</th><th>Device</th><th>Status</th><th></th></tr></thead>
            <tbody>
                @foreach (var ticket in Model.Tickets.Take(5))
                {
                    <tr><td>@ticket.TicketCode</td><td>@ticket.CustomerName</td><td>@ticket.Brand @ticket.DeviceModel</td><td><span class="badge text-bg-info">@ticket.Status</span></td><td><a class="btn btn-sm btn-outline-primary" asp-controller="Technician" asp-action="TaskDetails" asp-route-id="@ticket.RepairOrderId">View</a></td></tr>
                }
            </tbody>
        </table>
    </div>
</section>
