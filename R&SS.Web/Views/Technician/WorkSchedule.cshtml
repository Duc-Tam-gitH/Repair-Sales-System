@model TechnicalTicketListResponse
@{
    Layout = "_Layout";
    ViewData["Title"] = "Work Schedule";
    ViewData["ActiveRole"] = "Technician";
    ViewData["RoleDisplay"] = "Technician User";
}

@section Styles {
    <link rel="stylesheet" href="~/css/WorkSchedule.css" asp-append-version="true" />
}

<section class="work-schedule-page">
    <div class="schedule-header"><h1>Work Schedule</h1><p>Assigned technical tickets and completion deadlines.</p></div>
    <div class="schedule-list table-responsive mt-4">
        <h2>Task List</h2>
        <table class="table align-middle">
            <thead><tr><th>Task</th><th>Device</th><th>Customer</th><th>Status</th><th></th></tr></thead>
            <tbody>
                @foreach (var ticket in Model.Tickets)
                {
                    <tr><td>@ticket.TicketCode</td><td>@ticket.Brand @ticket.DeviceModel</td><td>@ticket.CustomerName</td><td><span class="badge text-bg-info">@ticket.Status</span></td><td><a class="btn btn-sm btn-outline-primary" asp-controller="Technician" asp-action="TaskDetails" asp-route-id="@ticket.RepairOrderId">Open</a></td></tr>
                }
            </tbody>
        </table>
    </div>
</section>
