@model TechnicianTaskViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Task Details";
    ViewData["ActiveRole"] = "Technician";
    ViewData["RoleDisplay"] = "Technician User";
}

@section Styles {
    <link rel="stylesheet" href="~/css/TaskDetails.css" asp-append-version="true" />
}

<section class="task-details-page">
    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success" role="status">@successMessage</div>
    }
    <div class="task-hero">
        <div><span>@Model.Ticket.TicketCode</span><h1>@Model.Ticket.Brand @Model.Ticket.DeviceModel Repair</h1><p>Status: @Model.Ticket.Status</p></div>
        <div class="action-stack">
            <a class="btn btn-light" asp-controller="Technician" asp-action="RecordFaults" asp-route-id="@Model.Ticket.RepairOrderId">Record Faults</a>
            <a class="btn btn-outline-light" asp-controller="Technician" asp-action="UpdateProgress" asp-route-id="@Model.Ticket.RepairOrderId">Update Progress</a>
            <a class="btn btn-outline-light" asp-controller="Technician" asp-action="RecordResults" asp-route-id="@Model.Ticket.RepairOrderId">Record Results</a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4"><section class="detail-card"><h2>Customer Info</h2><p><strong>Name:</strong> @Model.Ticket.CustomerName</p><p><strong>Phone:</strong> @Model.Ticket.CustomerPhone</p><p><strong>Email:</strong> @Model.Ticket.CustomerEmail</p></section></div>
        <div class="col-lg-4"><section class="detail-card"><h2>Device Info</h2><p><strong>Type:</strong> @Model.Ticket.DeviceType</p><p><strong>Brand/Model:</strong> @Model.Ticket.Brand / @Model.Ticket.DeviceModel</p><p><strong>Condition:</strong> @Model.Ticket.DeviceCondition</p></section></div>
        <div class="col-lg-4"><section class="detail-card"><h2>Initial Fault</h2><p>@Model.Ticket.IssueDescription</p></section></div>
    </div>

    <section class="progress-log mt-4">
        <h2>Repair History / Progress Log</h2>
        <div class="timeline">
            @foreach (var item in Model.History)
            {
                <div><span>@item.UpdatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd")</span><p>@item.Status - @item.Notes</p></div>
            }
        </div>
    </section>
</section>
