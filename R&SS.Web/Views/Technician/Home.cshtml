@{
    ViewData["Title"] = "Trang kỹ thuật viên";
    ViewData["ActiveRole"] = "Technician";
    ViewData["RoleDisplay"] = "Đăng nhập với vai trò Kỹ thuật viên";
}

<section class="rss-role-home rss-technician-home" aria-labelledby="technician-home-title">
    <header class="mb-4">
        <p class="text-muted mb-1">Không gian kỹ thuật viên</p>
        <h1 id="technician-home-title">Bàn làm việc kỹ thuật</h1>
        <p class="text-muted mb-0">Xem phiếu sửa chữa được giao, cập nhật tiến độ và quản lý ghi chú kỹ thuật.</p>
    </header>

    <nav class="rss-role-menu mb-4" aria-label="Menu kỹ thuật viên">
        <a href="#">Phiếu được giao</a>
        <a href="#">Cập nhật tiến độ</a>
        <a href="#">Lịch sử sửa chữa</a>
    </nav>

    <div class="row g-3 mb-4">
        <div class="col-md-3"><div class="rss-metric"><span>Đã giao</span><strong>7</strong></div></div>
        <div class="col-md-3"><div class="rss-metric"><span>Đang xử lý</span><strong>4</strong></div></div>
        <div class="col-md-3"><div class="rss-metric"><span>Chờ linh kiện</span><strong>2</strong></div></div>
        <div class="col-md-3"><div class="rss-metric"><span>Sẵn sàng hôm nay</span><strong>1</strong></div></div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3"><a class="rss-action rss-action-primary" href="#"><strong>Xem phiếu được giao</strong><span>Mở phiếu sửa chữa được giao cho bạn.</span></a></div>
        <div class="col-md-3"><a class="rss-action" href="#"><strong>Cập nhật tiến độ</strong><span>Đổi trạng thái và thêm ghi chú.</span></a></div>
        <div class="col-md-3"><a class="rss-action" href="#"><strong>Chờ linh kiện</strong><span>Xem các phiếu đang bị chặn.</span></a></div>
        <div class="col-md-3"><a class="rss-action" href="#"><strong>Lịch sử sửa chữa</strong><span>Kiểm tra công việc đã hoàn tất.</span></a></div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <section class="rss-panel" aria-labelledby="assigned-title">
                <header><h2 id="assigned-title">Phiếu được giao</h2></header>
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead><tr><th>Phiếu</th><th>Thiết bị</th><th>Ưu tiên</th><th>Trạng thái</th><th>Thao tác</th></tr></thead>
                        <tbody>
                            <tr><td>TT-1042</td><td>Laptop</td><td>Cao</td><td>Đang chẩn đoán</td><td><a href="#">Cập nhật</a></td></tr>
                            <tr><td>TT-1039</td><td>PC chơi game</td><td>Bình thường</td><td>Chờ linh kiện</td><td><a href="#">Thêm ghi chú</a></td></tr>
                            <tr><td>TT-1034</td><td>Điện thoại</td><td>Bình thường</td><td>Sẵn sàng</td><td><a href="#">Đóng</a></td></tr>
                        </tbody>
                    </table>
                </div>
            </section>
        </div>
        <div class="col-lg-4">
            <section class="rss-panel" aria-labelledby="quick-status-title">
                <header><h2 id="quick-status-title">Cập nhật nhanh trạng thái</h2></header>
                <form>
                    <label class="form-label" for="status">Trạng thái</label>
                    <select class="form-select" id="status">
                        <option>Đang chẩn đoán</option>
                        <option>Chờ linh kiện</option>
                        <option>Đang sửa chữa</option>
                        <option>Sẵn sàng nhận máy</option>
                    </select>
                    <label class="form-label mt-3" for="note">Ghi chú kỹ thuật viên</label>
                    <textarea class="form-control" id="note" rows="4"></textarea>
                </form>
            </section>
        </div>
    </div>
</section>
