@{
    Layout = "_Layout";
    ViewData["Title"] = "Component Search";
    ViewData["ActiveRole"] = "Technician";
    ViewData["RoleDisplay"] = "Technician User";
}

@section Styles {
    <link rel="stylesheet" href="~/css/ComponentSearch.css" asp-append-version="true" />
}

<!-- Data fetched via IComponentService.SearchComponents() -->
<section class="component-search-page">
    <div class="component-header"><h1>Tìm linh kiện / tra cứu tồn kho</h1><p>Tìm linh kiện thay thế và chọn linh kiện sử dụng cho công việc hiện tại.</p></div>
    <div class="component-tools"><input class="form-control" placeholder="Tìm theo tên hoặc mã linh kiện..." /><select class="form-select"><option>Tất cả loại</option><option>Màn hình</option><option>Pin</option><option>Cổng sạc</option><option>Camera</option><option>Bàn phím</option></select></div>
    <div class="component-table table-responsive">
        <table class="table align-middle">
            <thead><tr><th>Mã linh kiện</th><th>Tên</th><th>Loại</th><th>Số lượng tồn hiện tại</th><th>Vị trí/ô chứa</th><th></th></tr></thead>
            <tbody>
                <tr><td>CMP-KB-014</td><td>Module bàn phím Dell</td><td>Bàn phím</td><td>8</td><td>BIN-A12</td><td><a class="btn btn-sm btn-primary" asp-controller="Technician" asp-action="UpdateComponents">Chọn sử dụng</a></td></tr>
                <tr><td>CMP-BAT-022</td><td>Pin Nova X</td><td>Pin</td><td>3</td><td>BIN-B04</td><td><a class="btn btn-sm btn-primary" asp-controller="Technician" asp-action="UpdateComponents">Chọn sử dụng</a></td></tr>
                <tr><td>CMP-SCR-118</td><td>Cụm màn hình OLED</td><td>Màn hình</td><td>0</td><td>BIN-C02</td><td><a class="btn btn-sm btn-primary" asp-controller="Technician" asp-action="UpdateComponents">Chọn sử dụng</a></td></tr>
            </tbody>
        </table>
    </div>
</section>
