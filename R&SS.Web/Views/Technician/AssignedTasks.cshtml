@model TechnicalTicketListResponse
@{
    Layout = "_Layout";
    ViewData["Title"] = "Assigned Tasks";
    ViewData["ActiveRole"] = "Technician";
    ViewData["RoleDisplay"] = "Technician User";
}

@section Styles {
    <link rel="stylesheet" href="~/css/AssignedTasks.css" asp-append-version="true" />
}

<section class="assigned-tasks-page">
    <div class="task-list-header">
        <div><h1>Assigned Tasks</h1><p>Search assigned repair requests and continue technical work.</p></div>
        <a class="btn btn-primary" asp-controller="Technician" asp-action="WorkSchedule">View Schedule</a>
    </div>

    <div class="task-table table-responsive">
        <table class="table align-middle">
            <thead><tr><th>Task ID</th><th>Customer Name</th><th>Device</th><th>Status</th><th>Actions</th></tr></thead>
            <tbody>
                @if (!Model.Tickets.Any())
                {
                    <tr><td colspan="5">@Model.Message</td></tr>
                }
                else
                {
                    @foreach (var ticket in Model.Tickets)
                    {
                        <tr>
                            <td>@ticket.TicketCode</td>
                            <td>@ticket.CustomerName</td>
                            <td>@ticket.Brand @ticket.DeviceModel - @ticket.DeviceType</td>
                            <td><span class="badge text-bg-info">@ticket.Status</span></td>
                            <td>
                                <a class="btn btn-sm btn-outline-primary" asp-controller="Technician" asp-action="TaskDetails" asp-route-id="@ticket.RepairOrderId">View Details</a>
                                <a class="btn btn-sm btn-success" asp-controller="Technician" asp-action="RecordFaults" asp-route-id="@ticket.RepairOrderId">Start Processing</a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</section>
