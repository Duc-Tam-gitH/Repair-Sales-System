@model ForgotPasswordRequest
@{
    Layout = "_Layout";
    ViewData["Title"] = "Đặt lại mật khẩu";
}

@section Styles {
    <link rel="stylesheet" href="~/css/ForgotPassword.css" asp-append-version="true" />
}

<section class="password-page password-options-page" aria-labelledby="password-options-title">
    <div class="password-card password-options-card">
        <span class="password-badge">Bảo mật tài khoản</span>
        <h1 id="password-options-title">Đặt lại mật khẩu</h1>
        <p>Chọn cách phù hợp với trạng thái đăng nhập hiện tại của bạn.</p>

        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

        <div class="password-option-grid">
            <article class="password-option">
                <h2>Đổi mật khẩu khi đang đăng nhập</h2>
                <p>Sử dụng khi bạn vẫn nhớ mật khẩu hiện tại và muốn thay đổi ngay trong tài khoản.</p>
                <a class="btn btn-primary w-100" asp-controller="Account" asp-action="ChangePassword">Đổi mật khẩu</a>
            </article>

            <article class="password-option">
                <h2>Quên mật khẩu</h2>
                <p>Sử dụng OTP gửi qua email nếu bạn muốn đặt lại mật khẩu bằng xác thực một lần.</p>
                <form method="post" asp-controller="Account" asp-action="ForgotPassword">
                    @Html.AntiForgeryToken()
                    <label class="form-label" asp-for="Email">Email</label>
                    <input class="form-control" asp-for="Email" type="email" placeholder="you@example.com" required />
                    <span class="text-danger" asp-validation-for="Email"></span>
                    <button class="btn btn-outline-primary w-100 mt-3" type="submit">Gửi OTP</button>
                </form>
            </article>
        </div>
    </div>
</section>
