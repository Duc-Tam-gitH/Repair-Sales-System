@model PersonalInfoResponse
@{
    Layout = "_Layout";
    ViewData["Title"] = "Thông tin cá nhân";
}

@section Styles {
    <link rel="stylesheet" href="~/css/PersonalInfo.css" asp-append-version="true" />
}

<section class="profile-page" aria-labelledby="profile-title">
    <div class="profile-header">
        <div>
            <span>Tài khoản</span>
            <h1 id="profile-title">Thông tin cá nhân</h1>
            <p>Xem và cập nhật thông tin liên hệ của bạn.</p>
        </div>
        <a class="btn btn-outline-primary" asp-controller="Account" asp-action="ChangePassword">Đổi mật khẩu</a>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success" role="status">@successMessage</div>
    }
    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

    <form class="profile-card" method="post" asp-controller="Account" asp-action="PersonalInfo">
        @Html.AntiForgeryToken()
        <div class="row g-4">
            <div class="col-md-6">
                <label class="form-label" for="FullName">Họ và tên</label>
                <input class="form-control" id="FullName" name="FullName" type="text" value="@Model.FullName" />
            </div>
            <div class="col-md-6">
                <label class="form-label" for="Email">Email</label>
                <input class="form-control" id="Email" name="Email" type="email" value="@Model.Email" />
            </div>
            <div class="col-md-6">
                <label class="form-label" for="Phone">Số điện thoại</label>
                <input class="form-control" id="Phone" name="Phone" type="tel" value="@Model.Phone" />
            </div>
            <div class="col-12">
                <label class="form-label" for="Address">Địa chỉ</label>
                <textarea class="form-control" id="Address" name="Address" rows="4">@Model.Address</textarea>
            </div>
        </div>
        <button class="btn btn-primary mt-4" type="submit">Cập nhật</button>
    </form>
</section>
