@model ResetPasswordRequest
@{
    Layout = "_Layout";
    ViewData["Title"] = "Đặt lại mật khẩu";
}

@section Styles {
    <link rel="stylesheet" href="~/css/ResetPassword.css" asp-append-version="true" />
}

<section class="reset-page" aria-labelledby="reset-title">
    <div class="reset-card">
        <h1 id="reset-title">Đặt lại mật khẩu</h1>
        <p>Tạo mật khẩu mới cho tài khoản của bạn.</p>

        @if (TempData["SuccessMessage"] is string successMessage)
        {
            <div class="alert alert-success" role="status">@successMessage</div>
        }
        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

        <form method="post" asp-controller="Account" asp-action="ResetPassword">
            @Html.AntiForgeryToken()
            <input asp-for="Email" type="hidden" />
            <div class="mb-3">
                <label class="form-label" asp-for="NewPassword">Mật khẩu mới</label>
                <input class="form-control form-control-lg" asp-for="NewPassword" type="password" required />
                <span class="text-danger" asp-validation-for="NewPassword"></span>
            </div>
            <div class="mb-4">
                <label class="form-label" asp-for="ConfirmPassword">Xác nhận mật khẩu</label>
                <input class="form-control form-control-lg" asp-for="ConfirmPassword" type="password" required />
                <span class="text-danger" asp-validation-for="ConfirmPassword"></span>
            </div>
            <button class="btn btn-primary btn-lg w-100" type="submit">Cập nhật mật khẩu</button>
        </form>

        <a class="reset-return" asp-controller="Account" asp-action="Login">Quay lại đăng nhập</a>
    </div>
</section>
