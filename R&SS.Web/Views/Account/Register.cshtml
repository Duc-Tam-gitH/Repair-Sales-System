@model RegisterRequest
@{
    Layout = null;
    ViewData["Title"] = "Đăng ký";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng ký - Hệ thống Sửa chữa & Bán hàng</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/Register.css" asp-append-version="true" />
</head>
<body>
    <main class="register-page">
        <section class="register-card" aria-labelledby="register-title">
            <div class="register-heading">
                <span>R&SS</span>
                <div>
                    <h1 id="register-title">Tạo tài khoản</h1>
                    <p>Đăng ký để gửi yêu cầu dịch vụ, mua hàng và nhận hỗ trợ khách hàng.</p>
                </div>
            </div>

            <div asp-validation-summary="ModelOnly" class="alert alert-warning" role="alert"></div>

            <form method="post" asp-controller="Account" asp-action="Register">
                @Html.AntiForgeryToken()
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label" asp-for="FullName">Họ và tên</label>
                        <input class="form-control" asp-for="FullName" required />
                        <span class="text-danger" asp-validation-for="FullName"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" asp-for="Email">Email</label>
                        <input class="form-control" asp-for="Email" type="email" required />
                        <span class="text-danger" asp-validation-for="Email"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" asp-for="Phone">Số điện thoại</label>
                        <input class="form-control" asp-for="Phone" type="tel" />
                        <span class="text-danger" asp-validation-for="Phone"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" asp-for="Username">Tên đăng nhập</label>
                        <input class="form-control" asp-for="Username" required />
                        <span class="text-danger" asp-validation-for="Username"></span>
                    </div>
                    <div class="col-12">
                        <label class="form-label" asp-for="Address">Địa chỉ <span class="text-muted">(không bắt buộc)</span></label>
                        <textarea class="form-control" asp-for="Address" rows="2"></textarea>
                        <span class="text-danger" asp-validation-for="Address"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" asp-for="Password">Mật khẩu</label>
                        <input class="form-control" asp-for="Password" type="password" required />
                        <span class="text-danger" asp-validation-for="Password"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" asp-for="ConfirmPassword">Xác nhận mật khẩu</label>
                        <input class="form-control" asp-for="ConfirmPassword" type="password" required />
                        <span class="text-danger" asp-validation-for="ConfirmPassword"></span>
                    </div>
                </div>
                <button class="btn btn-success btn-lg w-100 mt-4" type="submit">Đăng ký</button>
            </form>

            <p class="register-footer">Đã có tài khoản? <a asp-controller="Account" asp-action="Login">Quay lại đăng nhập</a></p>
        </section>
    </main>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
