@model LoginRequest
@{
    Layout = null;
    ViewData["Title"] = "Đăng nhập";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - Hệ thống Sửa chữa & Bán hàng</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/Login.css" asp-append-version="true" />
</head>
<body>
    <main class="auth-page">
        <section class="auth-card" aria-labelledby="login-title">
            <div class="auth-brand">
                <div class="auth-logo">R&SS</div>
                <p>Hệ thống Sửa chữa & Bán hàng</p>
            </div>

            <h1 id="login-title">Chào mừng trở lại</h1>
            <p class="auth-subtitle">Đăng nhập để quản lý dịch vụ, đơn hàng, khách hàng và báo cáo.</p>

            @if (TempData["SuccessMessage"] is string successMessage)
            {
                <div class="alert alert-success" role="status">@successMessage</div>
            }

            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <form method="post" asp-controller="Account" asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label" asp-for="EmailOrUsername">Tên đăng nhập hoặc Email</label>
                    <input class="form-control form-control-lg" asp-for="EmailOrUsername" autocomplete="username" placeholder="Nhập tên đăng nhập hoặc email" required />
                    <span class="text-danger" asp-validation-for="EmailOrUsername"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label" asp-for="Password">Mật khẩu</label>
                    <input class="form-control form-control-lg" asp-for="Password" type="password" autocomplete="current-password" placeholder="Nhập mật khẩu" required />
                    <span class="text-danger" asp-validation-for="Password"></span>
                </div>
                <label class="form-check mb-3">
                    <input class="form-check-input" name="rememberMe" type="checkbox" value="true" />
                    <span class="form-check-label">Ghi nhớ đăng nhập</span>
                </label>
                <div class="auth-links">
                    <a asp-controller="Account" asp-action="ForgotPassword">Quên mật khẩu?</a>
                    <a asp-controller="Account" asp-action="Register">Tạo tài khoản</a>
                </div>
                <button class="btn btn-primary btn-lg w-100" type="submit">Đăng nhập</button>
            </form>
        </section>
    </main>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
