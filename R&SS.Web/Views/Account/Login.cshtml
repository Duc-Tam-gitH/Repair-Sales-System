@model LoginRequest
@{
    Layout = null;
    ViewData["Title"] = "Login";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - Repair & Sales System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/Login.css" asp-append-version="true" />
</head>
<body>
    <main class="auth-page">
        <section class="auth-card" aria-labelledby="login-title">
            <div class="auth-brand">
                <div class="auth-logo">R&SS</div>
                <p>Repair & Sales System</p>
            </div>

            <h1 id="login-title">Welcome back</h1>
            <p class="auth-subtitle">Sign in to manage services, orders, customers, and reports.</p>

            @if (TempData["SuccessMessage"] is string successMessage)
            {
                <div class="alert alert-success" role="status">@successMessage</div>
            }

            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <form method="post" asp-controller="Account" asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label" asp-for="EmailOrUsername">Username or Email</label>
                    <input class="form-control form-control-lg" asp-for="EmailOrUsername" autocomplete="username" placeholder="Enter your username or email" required />
                    <span class="text-danger" asp-validation-for="EmailOrUsername"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label" asp-for="Password">Password</label>
                    <input class="form-control form-control-lg" asp-for="Password" type="password" autocomplete="current-password" placeholder="Enter your password" required />
                    <span class="text-danger" asp-validation-for="Password"></span>
                </div>
                <label class="form-check mb-3">
                    <input class="form-check-input" name="rememberMe" type="checkbox" value="true" />
                    <span class="form-check-label">Remember me</span>
                </label>
                <div class="auth-links">
                    <a asp-controller="Account" asp-action="ForgotPassword">Forgot Password?</a>
                    <a asp-controller="Account" asp-action="Register">Create an account</a>
                </div>
                <button class="btn btn-primary btn-lg w-100" type="submit">Login</button>
            </form>
        </section>
    </main>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
