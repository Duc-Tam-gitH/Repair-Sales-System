@{
    Layout = null;
    ViewData["Title"] = "Login";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - Repair & Sales System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/Login.css" asp-append-version="true" />
</head>
<body>
    <main class="auth-page">
        <section class="auth-card" aria-labelledby="login-title">
            <div class="auth-brand">
                <div class="auth-logo">R&SS</div>
                <p>Repair & Sales System</p>
            </div>

            <h1 id="login-title">Welcome back</h1>
            <p class="auth-subtitle">Sign in to manage services, orders, customers, and reports.</p>

            <div class="alert alert-danger" role="alert">
                Invalid username or password.
            </div>

            <form method="post" asp-controller="Account" asp-action="Login">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label" for="username">Username</label>
                    <input class="form-control form-control-lg" id="username" name="EmailOrUsername" type="text" autocomplete="username" placeholder="Enter your username" required />
                </div>
                <div class="mb-3">
                    <label class="form-label" for="password">Password</label>
                    <input class="form-control form-control-lg" id="password" name="Password" type="password" autocomplete="current-password" placeholder="Enter your password" required />
                </div>
                <div class="auth-links">
                    <a asp-controller="Account" asp-action="ForgotPassword">Forgot Password?</a>
                    <a asp-controller="Account" asp-action="Register">Create an account</a>
                </div>
                <button class="btn btn-primary btn-lg w-100" type="submit">Login</button>
            </form>
        </section>
    </main>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
