@{
    Layout = "_Layout";
    ViewData["Title"] = "OTP Verification";
}

@section Styles {
    <link rel="stylesheet" href="~/css/VerifyOTP.css" asp-append-version="true" />
}

<section class="otp-page" aria-labelledby="otp-title">
    <div class="otp-card">
        <div class="otp-icon">OTP</div>
        <h1 id="otp-title">Verify OTP</h1>
        <p>Enter the 6-digit code sent to your registered email address.</p>

        <div class="alert alert-warning" role="alert">
            OTP has expired. Please request a new code.
        </div>

        <form method="post">
            <label class="form-label" for="otpCode">6-digit OTP Code</label>
            <input class="form-control form-control-lg otp-input" id="otpCode" name="OtpCode" type="text" inputmode="numeric" maxlength="6" placeholder="000000" required />
            <div class="d-flex gap-2 mt-4">
                <button class="btn btn-primary flex-fill" type="submit">Verify OTP</button>
                <button class="btn btn-outline-secondary flex-fill" type="button">Resend OTP</button>
            </div>
        </form>

        <a class="otp-return" asp-controller="Account" asp-action="ForgotPassword">Back to ForgotPassword</a>
    </div>
</section>
