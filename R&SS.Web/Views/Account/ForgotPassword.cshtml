@model ForgotPasswordRequest
@{
    Layout = "_Layout";
    ViewData["Title"] = "Quên mật khẩu";
}

@section Styles {
    <link rel="stylesheet" href="~/css/ForgotPassword.css" asp-append-version="true" />
}

<section class="password-page" aria-labelledby="forgot-title">
    <div class="password-card">
        <span class="password-badge">Khôi phục tài khoản</span>
        <h1 id="forgot-title">Quên mật khẩu</h1>
        <p>Nhập địa chỉ email, hệ thống sẽ gửi mã xác thực một lần.</p>

        @if (TempData["SuccessMessage"] is string successMessage)
        {
            <div class="alert alert-success" role="status">@successMessage</div>
        }
        else
        {
            <div class="alert alert-info" role="status">
                Mã OTP sẽ được gửi đến email liên kết với tài khoản của bạn.
            </div>
        }
        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

        <form method="post" asp-controller="Account" asp-action="ForgotPassword">
            @Html.AntiForgeryToken()
            <label class="form-label" asp-for="Email">Email</label>
            <input class="form-control form-control-lg" asp-for="Email" type="email" placeholder="you@example.com" required />
            <span class="text-danger" asp-validation-for="Email"></span>
            <div class="d-flex gap-2 mt-4">
                <button class="btn btn-primary flex-fill" type="submit">Gửi OTP</button>
            </div>
        </form>

        <a class="password-return" asp-controller="Account" asp-action="Login">Quay lại đăng nhập</a>
    </div>
</section>
