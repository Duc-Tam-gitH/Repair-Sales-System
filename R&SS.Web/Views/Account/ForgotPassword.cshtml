@model ForgotPasswordRequest
@{
    Layout = "_Layout";
    ViewData["Title"] = "Forgot Password";
}

@section Styles {
    <link rel="stylesheet" href="~/css/ForgotPassword.css" asp-append-version="true" />
}

<section class="password-page" aria-labelledby="forgot-title">
    <div class="password-card">
        <span class="password-badge">Account Recovery</span>
        <h1 id="forgot-title">Forgot Password</h1>
        <p>Enter your email address and we will send a one-time verification code.</p>

        @if (TempData["SuccessMessage"] is string successMessage)
        {
            <div class="alert alert-success" role="status">@successMessage</div>
        }
        else
        {
            <div class="alert alert-info" role="status">
                OTP will be sent to the email linked to your account.
            </div>
        }
        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

        <form method="post" asp-controller="Account" asp-action="ForgotPassword">
            @Html.AntiForgeryToken()
            <label class="form-label" asp-for="Email">Email</label>
            <input class="form-control form-control-lg" asp-for="Email" type="email" placeholder="you@example.com" required />
            <span class="text-danger" asp-validation-for="Email"></span>
            <div class="d-flex gap-2 mt-4">
                <button class="btn btn-primary flex-fill" type="submit">Send OTP</button>
            </div>
        </form>

        <a class="password-return" asp-controller="Account" asp-action="Login">Back to Login</a>
    </div>
</section>
