@{
    Layout = "_Layout";
    ViewData["Title"] = "Forgot Password";
}

@section Styles {
    <link rel="stylesheet" href="~/css/ForgotPassword.css" asp-append-version="true" />
}

<section class="password-page" aria-labelledby="forgot-title">
    <div class="password-card">
        <span class="password-badge">Account Recovery</span>
        <h1 id="forgot-title">Forgot Password</h1>
        <p>Enter your email address and we will send a one-time verification code.</p>

        <div class="alert alert-info" role="status">
            OTP will be sent to the email linked to your account.
        </div>

        <form method="post">
            <label class="form-label" for="email">Email</label>
            <input class="form-control form-control-lg" id="email" name="Email" type="email" placeholder="you@example.com" required />
            <div class="d-flex gap-2 mt-4">
                <button class="btn btn-primary flex-fill" type="submit">Send OTP</button>
                <button class="btn btn-outline-primary flex-fill" type="button">Resend OTP</button>
            </div>
        </form>

        <a class="password-return" asp-controller="Account" asp-action="Login">Back to Login</a>
    </div>
</section>
