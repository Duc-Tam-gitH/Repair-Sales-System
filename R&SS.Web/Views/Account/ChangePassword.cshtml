@model ChangePasswordRequest
@{
    Layout = "_Layout";
    ViewData["Title"] = "Change Password";
}

@section Styles {
    <link rel="stylesheet" href="~/css/ChangePassword.css" asp-append-version="true" />
}

<section class="change-password-page" aria-labelledby="change-password-title">
    <div class="change-password-card">
        <h1 id="change-password-title">Change Password</h1>
        <p>Use a strong password that you do not use elsewhere.</p>

        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

        <form method="post" asp-controller="Account" asp-action="ChangePassword">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label" asp-for="CurrentPassword">Current Password</label>
                <input class="form-control" asp-for="CurrentPassword" type="password" required />
                <span class="text-danger" asp-validation-for="CurrentPassword"></span>
            </div>
            <div class="mb-3">
                <label class="form-label" asp-for="NewPassword">New Password</label>
                <input class="form-control" asp-for="NewPassword" type="password" required />
                <span class="text-danger" asp-validation-for="NewPassword"></span>
            </div>
            <div class="mb-4">
                <label class="form-label" asp-for="ConfirmNewPassword">Confirm New Password</label>
                <input class="form-control" asp-for="ConfirmNewPassword" type="password" required />
                <span class="text-danger" asp-validation-for="ConfirmNewPassword"></span>
            </div>
            <button class="btn btn-primary w-100" type="submit">Change Password</button>
        </form>
    </div>
</section>
