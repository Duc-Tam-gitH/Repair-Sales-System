@model ProductCategoryManagementViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Quản lý danh mục";
    ViewData["ActiveRole"] = "ProductManagement";
    ViewData["RoleDisplay"] = "Nhân viên sản phẩm";
}

@section Styles {
    <link rel="stylesheet" href="~/css/CategoryManagement.css" asp-append-version="true" />
}

<section class="category-management-page">
    <div class="product-admin-header">
        <div><span>Thiết lập danh mục</span><h1>Quản lý danh mục sản phẩm</h1><p>Quản lý các danh mục bán hàng đang dùng và đã ngừng dùng trong danh mục sản phẩm.</p></div>
        <a class="btn btn-primary" asp-controller="ProductManagement" asp-action="ProductList">Sản phẩm</a>
    </div>

    @if (TempData["SuccessMessage"] is string success)
    {
        <div class="alert alert-success" role="status">@success</div>
    }
    @if (TempData["ErrorMessage"] is string error)
    {
        <div class="alert alert-warning" role="alert">@error</div>
    }
    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

    <form class="category-tools" method="get" asp-controller="ProductManagement" asp-action="CategoryManagement">
        <input class="form-control" name="keyword" value="@Model.Keyword" type="search" placeholder="Tìm theo tên danh mục..." />
        <button class="btn btn-outline-primary" type="submit">Tìm kiếm</button>
    </form>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="table-card table-responsive">
                <table class="table align-middle">
                    <thead><tr><th>Mã danh mục</th><th>Tên danh mục</th><th>Mô tả</th><th>Trạng thái</th><th>Thao tác</th></tr></thead>
                    <tbody>
                        @if (!Model.Categories.Any())
                        {
                            <tr><td colspan="5" class="text-center text-muted">Không tìm thấy danh mục.</td></tr>
                        }
                        else
                        {
                            @foreach (var category in Model.Categories)
                            {
                                var editFormId = $"edit-category-{category.ProductCategoryId}";
                                var deleteFormId = $"delete-category-{category.ProductCategoryId}";
                                <tr>
                                    <td>@category.CategoryCode</td>
                                    <td>
                                        <form id="@editFormId" method="post" asp-controller="ProductManagement" asp-action="EditCategory">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="ProductCategoryId" value="@category.ProductCategoryId" />
                                        </form>
                                        <input class="form-control" form="@editFormId" name="CategoryName" value="@category.CategoryName" required maxlength="100" />
                                    </td>
                                    <td><input class="form-control" form="@editFormId" name="Description" value="@category.Description" maxlength="255" /></td>
                                    <td>
                                        <select class="form-select form-select-sm" form="@editFormId" name="IsActive">
                                            <option value="true" selected="@category.IsActive">Đang hoạt động</option>
                                            <option value="false" selected="@(!category.IsActive)">Ngừng sử dụng</option>
                                        </select>
                                    </td>
                                    <td>
                                        <div class="d-flex gap-2">
                                            <button class="btn btn-sm btn-outline-secondary" form="@editFormId" type="submit">Sửa</button>
                                            <form id="@deleteFormId" method="post" asp-controller="ProductManagement" asp-action="DeleteCategory">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="categoryId" value="@category.ProductCategoryId" />
                                            </form>
                                            <button class="btn btn-sm btn-outline-danger" form="@deleteFormId" type="submit">Xóa</button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="col-lg-4">
            <form class="category-form" method="post" asp-controller="ProductManagement" asp-action="AddCategory">
                @Html.AntiForgeryToken()
                <h2>Thêm danh mục</h2>
                <label class="form-label" for="CategoryName">Tên danh mục</label>
                <input class="form-control" id="CategoryName" name="CategoryName" value="@Model.Category.CategoryName" required maxlength="100" />
                <label class="form-label mt-3" for="Description">Mô tả</label>
                <textarea class="form-control" id="Description" name="Description" rows="4" maxlength="255">@Model.Category.Description</textarea>
                <button class="btn btn-primary w-100 mt-4" type="submit">Lưu</button>
            </form>
        </div>
    </div>
</section>
