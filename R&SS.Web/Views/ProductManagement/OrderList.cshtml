@model ProductOrderListViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Quản lý đơn hàng";
    ViewData["ActiveRole"] = "ProductManagement";
    ViewData["RoleDisplay"] = "Nhân viên sản phẩm";
}

@section Styles {
    <link rel="stylesheet" href="~/css/ProductManagementOrderList.css" asp-append-version="true" />
}

<section class="order-management-page">
    <div class="product-admin-header">
        <div><span>Đơn hàng khách hàng</span><h1>Quản lý đơn hàng</h1><p>Xem đơn hàng, khách hàng, tổng tiền và trạng thái hủy.</p></div>
        <a class="btn btn-outline-primary" asp-controller="ProductManagement" asp-action="OrderList">Làm mới</a>
    </div>

    @if (TempData["SuccessMessage"] is string success)
    {
        <div class="alert alert-success" role="status">@success</div>
    }
    @if (TempData["ErrorMessage"] is string error)
    {
        <div class="alert alert-danger" role="alert">@error</div>
    }
    <form class="order-tools" method="get" asp-controller="ProductManagement" asp-action="OrderList">
        <input class="form-control" name="keyword" value="@Model.Keyword" placeholder="Tìm theo mã đơn hàng hoặc tên khách hàng..." />
        <select class="form-select" name="status">
            <option value="">Tất cả trạng thái</option>
            @foreach (var status in Model.Orders.Select(order => order.Status).Distinct().OrderBy(value => value))
            {
                <option value="@status" selected="@(Model.Status == status)">@status</option>
            }
        </select>
        <button class="btn btn-outline-primary" type="submit">Lọc</button>
    </form>

    <div class="table-card table-responsive">
        <table class="table align-middle">
            <thead><tr><th>Mã đơn hàng</th><th>Tên khách hàng</th><th>Ngày đặt hàng</th><th>Tổng tiền</th><th>Trạng thái</th><th>Mặt hàng</th><th>Thao tác</th></tr></thead>
            <tbody>
                @if (!Model.Orders.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted">Không tìm thấy đơn hàng.</td></tr>
                }
                else
                {
                    @foreach (var order in Model.Orders)
                    {
                        <tr>
                            <td>@order.SalesOrderCode</td>
                            <td>@(order.Customer?.FullName ?? "Khách hàng")</td>
                            <td>@order.SalesDate.ToLocalTime().ToString("yyyy-MM-dd")</td>
                            <td>@order.TotalAmount.ToString("C")</td>
                            <td><span class="badge text-bg-info">@order.Status</span></td>
                            <td>@order.SalesOrderDetails.Sum(detail => detail.Quantity)</td>
                            <td>
                                @if (order.Status.Equals("Pending Confirmation", StringComparison.OrdinalIgnoreCase) || order.Status.Equals("Being Prepared", StringComparison.OrdinalIgnoreCase))
                                {
                                    <form method="post" asp-controller="ProductManagement" asp-action="CancelOrder">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="salesOrderId" value="@order.SalesOrderId" />
                                        <input type="hidden" name="reason" value="Cancelled by product management." />
                                        <button class="btn btn-sm btn-outline-danger" type="submit">Hủy</button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-muted">Không có thao tác</span>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</section>
