@model ProductCatalogViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Product Management";
    ViewData["ActiveRole"] = "ProductManagement";
    ViewData["RoleDisplay"] = "Product Staff";
}

@section Styles {
    <link rel="stylesheet" href="~/css/ProductManagementProductList.css" asp-append-version="true" />
}

<section class="product-management-list-page">
    <div class="product-admin-header">
        <div><span>Product Catalog</span><h1>Product Management</h1><p>Maintain sellable products, prices, stock quantities, and catalog status.</p></div>
        <a class="btn btn-primary" asp-controller="ProductManagement" asp-action="AddUpdateProduct">Add Product</a>
    </div>

    @if (TempData["SuccessMessage"] is string success)
    {
        <div class="alert alert-success" role="status">@success</div>
    }
    @if (TempData["ErrorMessage"] is string error)
    {
        <div class="alert alert-danger" role="alert">@error</div>
    }
    <form class="product-tools" method="get" asp-controller="ProductManagement" asp-action="ProductList">
        <input class="form-control" name="keyword" value="@Model.Keyword" placeholder="Search by Product Name or Code..." />
        <button class="btn btn-outline-primary" type="submit">Search</button>
    </form>

    <div class="table-card table-responsive">
        <table class="table align-middle">
            <thead><tr><th>Product Code</th><th>Product Name</th><th>Category</th><th>Price</th><th>Stock Quantity</th><th>Status</th><th>Actions</th></tr></thead>
            <tbody>
                @if (!Model.Products.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted">No products found.</td></tr>
                }
                else
                {
                    @foreach (var product in Model.Products)
                    {
                        <tr>
                            <td>@product.ProductCode</td>
                            <td>@product.ProductName</td>
                            <td>@(product.CategoryName ?? "Uncategorized")</td>
                            <td>@product.SalePrice.ToString("C")</td>
                            <td>@product.QuantityInStock</td>
                            <td><span class="badge @(product.QuantityInStock > 0 ? "text-bg-success" : "text-bg-secondary")">@(product.QuantityInStock > 0 ? "Active" : "No Stock")</span></td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a class="btn btn-sm btn-outline-primary" asp-controller="ProductManagement" asp-action="ProductDetails" asp-route-id="@product.ProductId">View</a>
                                    <a class="btn btn-sm btn-outline-secondary" asp-controller="ProductManagement" asp-action="AddUpdateProduct" asp-route-id="@product.ProductId">Edit</a>
                                    <form method="post" asp-controller="ProductManagement" asp-action="DeleteProduct">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="productId" value="@product.ProductId" />
                                        <button class="btn btn-sm btn-outline-warning" type="submit">Delete</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</section>
