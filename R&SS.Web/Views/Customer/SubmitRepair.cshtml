@model SendServiceRequestRequest
@{
    Layout = "_Layout";
    ViewData["Title"] = "Submit Repair Request";
    ViewData["ActiveRole"] = "Customer";
    ViewData["RoleDisplay"] = "Customer User";
}

@section Styles {
    <link rel="stylesheet" href="~/css/SubmitRepair.css" asp-append-version="true" />
}

<section class="submit-repair-page">
    <div class="repair-intro">
        <span>Technical Service</span>
        <h1>Submit Repair Request</h1>
        <p>Tell us about your device issue so reception can process it.</p>
    </div>

    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

    <form class="repair-form" method="post" asp-controller="Customer" asp-action="SubmitRepair">
        @Html.AntiForgeryToken()
        <h2>Device Information</h2>
        <div class="row g-3">
            <div class="col-md-6"><label class="form-label" asp-for="ServiceType">Service Type</label><select class="form-select" asp-for="ServiceType"><option>Repair</option><option>Maintenance</option><option>Inspection</option></select></div>
            <div class="col-md-6"><label class="form-label" asp-for="DeviceType">Device Type</label><select class="form-select" asp-for="DeviceType"><option>Phone</option><option>Laptop</option><option>Tablet</option><option>Printer</option><option>Other</option></select></div>
            <div class="col-md-6"><label class="form-label" asp-for="Brand">Brand</label><input class="form-control" asp-for="Brand" placeholder="e.g., Dell" required /></div>
            <div class="col-md-6"><label class="form-label" asp-for="DeviceModel">Device Model</label><input class="form-control" asp-for="DeviceModel" placeholder="e.g., Inspiron 15" /></div>
            <div class="col-12"><label class="form-label" asp-for="Description">Fault Description</label><textarea class="form-control" asp-for="Description" rows="5" placeholder="Describe the issue, symptoms, and when it started." required></textarea></div>
        </div>
        <button class="btn btn-primary mt-4" type="submit">Submit Repair Request</button>
    </form>
</section>
