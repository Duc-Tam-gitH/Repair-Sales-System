@model IReadOnlyCollection<R_SS.Models.Entities.RepairOrder>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Repair Progress";
    ViewData["ActiveRole"] = "Customer";
    ViewData["RoleDisplay"] = "Customer User";
}

@section Styles {
    <link rel="stylesheet" href="~/css/RepairProgress.css" asp-append-version="true" />
}

<section class="repair-progress-page">
    <div class="progress-header">
        <h1>Track Repair Progress</h1>
        <a class="btn btn-primary" asp-controller="Customer" asp-action="SubmitRepair">New Repair Request</a>
    </div>

    @if (!Model.Any())
    {
        <article class="repair-ticket"><h2>No active repairs found</h2></article>
    }
    else
    {
        @foreach (var repair in Model)
        {
            <article class="repair-ticket">
                <div class="ticket-top">
                    <div><span>@repair.RepairOrderCode</span><h2>@repair.DeviceName</h2></div>
                    <strong class="state progress-state">@repair.Status</strong>
                </div>
                <p><strong>Assigned Technician:</strong> @(repair.AssignedTechnician?.FullName ?? "Pending assignment")</p>
                <div class="timeline">
                    @foreach (var history in repair.StatusHistories.OrderBy(history => history.UpdatedAtUtc))
                    {
                        <div><span>@history.UpdatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd")</span><p>@(history.Notes ?? history.Status)</p></div>
                    }
                </div>
                <div class="parts-box"><strong>Parts Used:</strong> @string.Join(", ", repair.RepairOrderDetails.Select(detail => detail.Product?.ProductName).Where(name => !string.IsNullOrWhiteSpace(name)))</div>
                <div class="result-box"><strong>Final Repair Results:</strong> @(repair.RepairResult ?? "Pending final result.")</div>
            </article>
        }
    }
</section>
