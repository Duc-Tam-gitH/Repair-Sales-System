@model IReadOnlyCollection<R_SS.Models.Entities.RepairOrder>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Lịch sử sửa chữa";
    ViewData["ActiveRole"] = "Customer";
    ViewData["RoleDisplay"] = "Khách hàng";
}

@section Styles {
    <link rel="stylesheet" href="~/css/RepairHistory.css" asp-append-version="true" />
}

<section class="repair-history-page">
    <div class="history-header">
        <h1>Lịch sử sửa chữa</h1>
        <p>Các báo cáo dịch vụ đã hoàn tất cho thiết bị bạn từng sửa chữa.</p>
    </div>

    <div class="row g-4">
        @if (!Model.Any())
        {
            <div class="col-12"><article class="history-card"><h2>Chưa có lịch sử sửa chữa</h2></article></div>
        }
        else
        {
            @foreach (var repair in Model)
            {
                <div class="col-lg-6">
                    <article class="history-card">
                        <span>@repair.RepairOrderCode</span>
                        <h2>@repair.DeviceName</h2>
                        <p><strong>Giải pháp sửa chữa:</strong> @(repair.WorkPerformed ?? repair.RepairResult ?? "Chưa ghi nhận tóm tắt sửa chữa.")</p>
                        <p><strong>Linh kiện đã thay:</strong> @string.Join(", ", repair.RepairOrderDetails.Select(detail => detail.Product?.ProductName).Where(name => !string.IsNullOrWhiteSpace(name)))</p>
                        <p><strong>Chi phí sửa chữa:</strong> @repair.TotalAmount.ToString("C")</p>
                    </article>
                </div>
            }
        }
    </div>
</section>
