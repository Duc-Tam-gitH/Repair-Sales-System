@model IReadOnlyCollection<R_SS.Models.Entities.RepairOrder>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Repair History";
    ViewData["ActiveRole"] = "Customer";
    ViewData["RoleDisplay"] = "Customer User";
}

@section Styles {
    <link rel="stylesheet" href="~/css/RepairHistory.css" asp-append-version="true" />
}

<section class="repair-history-page">
    <div class="history-header">
        <h1>Repair History</h1>
        <p>Completed service reports for your previously repaired devices.</p>
    </div>

    <div class="row g-4">
        @if (!Model.Any())
        {
            <div class="col-12"><article class="history-card"><h2>No repair history found</h2></article></div>
        }
        else
        {
            @foreach (var repair in Model)
            {
                <div class="col-lg-6">
                    <article class="history-card">
                        <span>@repair.RepairOrderCode</span>
                        <h2>@repair.DeviceName</h2>
                        <p><strong>Repair Solution:</strong> @(repair.WorkPerformed ?? repair.RepairResult ?? "No repair summary recorded.")</p>
                        <p><strong>Replaced Parts:</strong> @string.Join(", ", repair.RepairOrderDetails.Select(detail => detail.Product?.ProductName).Where(name => !string.IsNullOrWhiteSpace(name)))</p>
                        <p><strong>Repair Cost:</strong> @repair.TotalAmount.ToString("C")</p>
                    </article>
                </div>
            }
        }
    </div>
</section>
