@model ProductListResponse
@{
    Layout = "_Layout";
    ViewData["Title"] = "Product Catalog";
    ViewData["ActiveRole"] = "Customer";
    ViewData["RoleDisplay"] = "Customer User";
}

@section Styles {
    <link rel="stylesheet" href="~/css/ProductList.css" asp-append-version="true" />
}

<section class="catalog-page">
    <div class="catalog-header">
        <div>
            <h1>Product Catalog</h1>
            <p>Search products, filter by category, and open product details before purchase.</p>
        </div>
        <a class="btn btn-primary" asp-controller="Customer" asp-action="Cart">View Cart</a>
    </div>

    <form class="catalog-tools" method="get" asp-controller="Customer" asp-action="ProductList">
        <input class="form-control form-control-lg" name="keyword" type="search" value="@ViewData["Keyword"]" placeholder="Search products by name, category, or brand..." />
        <select class="form-select" name="criteria" aria-label="Search criteria">
            <option value="all" selected="@(ViewData["Criteria"]?.ToString() == "all")">All</option>
            <option value="name" selected="@(ViewData["Criteria"]?.ToString() == "name")">Name</option>
            <option value="category" selected="@(ViewData["Criteria"]?.ToString() == "category")">Category</option>
            <option value="brand" selected="@(ViewData["Criteria"]?.ToString() == "brand")">Brand</option>
        </select>
        <button class="btn btn-outline-primary" type="submit">Search</button>
    </form>

    <div asp-validation-summary="ModelOnly" class="alert alert-warning" role="alert"></div>

    <div class="row g-4">
        @if (!Model.Products.Any())
        {
            <div class="col-12">
                <article class="catalog-card">
                    <h2>No products found</h2>
                    <p>@Model.Message</p>
                </article>
            </div>
        }
        else
        {
            @foreach (var product in Model.Products)
            {
                <div class="col-md-6 col-xl-4">
                    <article class="catalog-card">
                        <span class="stock @(product.QuantityInStock > 0 ? "in-stock" : "out-stock")">
                            @(product.QuantityInStock > 0 ? "In Stock" : "Out of Stock")
                        </span>
                        <h2>@product.ProductName</h2>
                        <p>@(product.CategoryName ?? product.BrandName ?? product.ProductCode)</p>
                        <strong>@product.SalePrice.ToString("C")</strong>
                        <a class="btn btn-sm btn-outline-primary" asp-controller="Customer" asp-action="ProductDetails" asp-route-id="@product.ProductId">View Details</a>
                    </article>
                </div>
            }
        }
    </div>
</section>
