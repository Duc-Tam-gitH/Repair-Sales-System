@model IReadOnlyCollection<OrderResponse>
@{
    Layout = "_Layout";
    ViewData["Title"] = "My Orders";
    ViewData["ActiveRole"] = "Customer";
    ViewData["RoleDisplay"] = "Customer User";
}

@section Styles {
    <link rel="stylesheet" href="~/css/MyOrders.css" asp-append-version="true" />
}

<section class="orders-page">
    <div class="orders-header">
        <h1>My Orders</h1>
        <form method="get" asp-controller="Customer" asp-action="MyOrders">
            <input class="form-control" name="keyword" type="search" value="@ViewData["Keyword"]" placeholder="Search by order code..." />
        </form>
    </div>
    <div class="orders-panel table-responsive">
        <table class="table align-middle">
            <thead><tr><th>Order Code</th><th>Status</th><th>Total Amount</th><th>Actions</th></tr></thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="4">No orders found.</td></tr>
                }
                else
                {
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td>@order.SalesOrderCode</td>
                            <td><span class="badge text-bg-info">@order.Status</span></td>
                            <td>@order.TotalAmount.ToString("C")</td>
                            <td><a class="btn btn-sm btn-outline-primary" asp-controller="Customer" asp-action="OrderDetails" asp-route-id="@order.SalesOrderId">View Details</a></td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</section>
