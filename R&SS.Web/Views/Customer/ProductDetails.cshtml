@model ProductDetailResponse
@{
    Layout = "_Layout";
    ViewData["Title"] = "Product Details";
    ViewData["ActiveRole"] = "Customer";
    ViewData["RoleDisplay"] = "Customer User";
}

@section Styles {
    <link rel="stylesheet" href="~/css/ProductDetails.css" asp-append-version="true" />
}

<section class="product-detail-page">
    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="alert alert-danger" role="alert">@errorMessage</div>
    }
    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success" role="status">@successMessage</div>
    }
    <div class="row g-4">
        <div class="col-lg-6">
            <div id="productCarousel" class="carousel slide product-carousel">
                <div class="carousel-inner">
                    <div class="carousel-item active"><div class="product-slide">@Model.ProductName</div></div>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="detail-panel">
                <span class="availability">@(Model.QuantityInStock > 0 ? "In Stock" : "Out of Stock")</span>
                <h1>@Model.ProductName</h1>
                <p>@(Model.Description ?? "No description is available for this product.")</p>
                <strong class="price">@Model.SalePrice.ToString("C")</strong>
                <form method="post" asp-controller="Customer" asp-action="AddToCart">
                    @Html.AntiForgeryToken()
                    <input name="ProductId" type="hidden" value="@Model.ProductId" />
                    <label class="form-label mt-3" for="quantity">Quantity</label>
                    <input class="form-control quantity-input" id="quantity" name="Quantity" type="number" min="1" max="@Model.QuantityInStock" value="1" />
                    <button class="btn btn-primary w-100 mt-4" type="submit" disabled="@(Model.QuantityInStock <= 0)">Add to Cart</button>
                </form>
                <div class="d-flex gap-2 mt-3">
                    <a class="btn btn-outline-primary flex-fill" asp-controller="Customer" asp-action="ProductList">Back to Products</a>
                    <a class="btn btn-success flex-fill" asp-controller="Customer" asp-action="Checkout">Buy Now</a>
                </div>
            </div>
        </div>
    </div>

    <section class="spec-panel mt-4">
        <h2>Specifications</h2>
        <table class="table">
            <tbody>
                <tr><th>CPU</th><td>Intel Core i5</td></tr>
                <tr><th>Product Code</th><td>@Model.ProductCode</td></tr>
                <tr><th>Category</th><td>@(Model.CategoryName ?? "Uncategorized")</td></tr>
                <tr><th>Brand/Supplier</th><td>@(Model.BrandName ?? "N/A")</td></tr>
                <tr><th>Available Stock</th><td>@Model.QuantityInStock</td></tr>
            </tbody>
        </table>
    </section>
</section>
