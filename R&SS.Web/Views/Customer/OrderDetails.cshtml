@model OrderResponse
@{
    Layout = "_Layout";
    ViewData["Title"] = "Order Details";
    ViewData["ActiveRole"] = "Customer";
    ViewData["RoleDisplay"] = "Customer User";
}

@section Styles {
    <link rel="stylesheet" href="~/css/OrderDetails.css" asp-append-version="true" />
}

<section class="order-detail-page">
    <div class="order-banner">
        <div><span>Order Code</span><h1>@Model.SalesOrderCode</h1></div>
        <span class="status">@Model.Status</span>
    </div>
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="detail-card table-responsive">
                <h2>Products</h2>
                <table class="table align-middle">
                    <thead><tr><th>Name</th><th>Quantity</th><th>Unit Price</th><th>Total</th></tr></thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr><td>@item.ProductName</td><td>@item.Quantity</td><td>@item.UnitPrice.ToString("C")</td><td>@item.LineTotal.ToString("C")</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="col-lg-4">
            <aside class="detail-card">
                <h2>Summary</h2>
                <p><strong>Payment:</strong> @Model.PaymentMethod</p>
                <p><strong>Subtotal:</strong> @Model.SubTotal.ToString("C")</p>
                <p><strong>Discount:</strong> @Model.DiscountAmount.ToString("C")</p>
                <p><strong>Total:</strong> @Model.TotalAmount.ToString("C")</p>
                <p><strong>Notes:</strong> @Model.Message</p>
            </aside>
        </div>
    </div>
</section>
