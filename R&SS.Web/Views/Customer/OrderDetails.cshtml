@model OrderResponse
@{
    Layout = "_Layout";
    ViewData["Title"] = "Chi tiết đơn hàng";
    ViewData["ActiveRole"] = "Customer";
    ViewData["RoleDisplay"] = "Khách hàng";
}

@section Styles {
    <link rel="stylesheet" href="~/css/OrderDetails.css" asp-append-version="true" />
}

<section class="order-detail-page">
    <div class="order-banner">
        <div><span>Mã đơn hàng</span><h1>@Model.SalesOrderCode</h1></div>
        <span class="status">@Model.Status</span>
    </div>
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="detail-card table-responsive">
                <h2>Sản phẩm</h2>
                <table class="table align-middle">
                    <thead><tr><th>Tên sản phẩm</th><th>Số lượng</th><th>Đơn giá</th><th>Thành tiền</th></tr></thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr><td>@item.ProductName</td><td>@item.Quantity</td><td>@item.UnitPrice.ToString("C")</td><td>@item.LineTotal.ToString("C")</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="col-lg-4">
            <aside class="detail-card">
                <h2>Tóm tắt</h2>
                <p><strong>Thanh toán:</strong> @Model.PaymentMethod</p>
                <p><strong>Tạm tính:</strong> @Model.SubTotal.ToString("C")</p>
                <p><strong>Giảm giá:</strong> @Model.DiscountAmount.ToString("C")</p>
                <p><strong>Tổng cộng:</strong> @Model.TotalAmount.ToString("C")</p>
                <p><strong>Ghi chú:</strong> @Model.Message</p>
            </aside>
        </div>
    </div>
</section>
