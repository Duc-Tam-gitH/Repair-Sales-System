@{
    Layout = "_Layout";
    ViewData["Title"] = "Order Details";
    ViewData["ActiveRole"] = "Customer";
    ViewData["RoleDisplay"] = "Customer User";
}

@section Styles {
    <link rel="stylesheet" href="~/css/OrderDetails.css" asp-append-version="true" />
}

@* Order details simulate data from IOrderService. *@
<section class="order-detail-page">
    <div class="order-banner">
        <div><span>Order Code</span><h1>SO-2026-1042</h1></div>
        <span class="status">Pending</span>
    </div>
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="detail-card table-responsive">
                <h2>Products</h2>
                <table class="table align-middle">
                    <thead><tr><th>Name</th><th>Quantity</th><th>Unit Price</th><th>Total</th></tr></thead>
                    <tbody>
                        <tr><td>ProBook 14</td><td>1</td><td>$849</td><td>$849</td></tr>
                        <tr><td>Wireless Mouse</td><td>2</td><td>$24</td><td>$48</td></tr>
                        <tr><td>USB-C Service Kit</td><td>1</td><td>$39</td><td>$39</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
        <div class="col-lg-4">
            <aside class="detail-card">
                <h2>Summary</h2>
                <p><strong>Date:</strong> 2026-07-18</p>
                <p><strong>Payment:</strong> Cash</p>
                <p><strong>Total:</strong> $936</p>
                <p><strong>Delivery Address:</strong> 123 Customer Avenue</p>
            </aside>
        </div>
    </div>
</section>
