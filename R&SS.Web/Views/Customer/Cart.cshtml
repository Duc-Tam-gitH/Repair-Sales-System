@model CartResponse
@{
    Layout = "_Layout";
    ViewData["Title"] = "Shopping Cart";
    ViewData["ActiveRole"] = "Customer";
    ViewData["RoleDisplay"] = "Customer User";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Cart.css" asp-append-version="true" />
}

<section class="cart-page">
    <div class="cart-header">
        <h1>Shopping Cart</h1>
        <a class="btn btn-outline-primary" asp-controller="Customer" asp-action="ProductList">Continue Shopping</a>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success" role="status">@successMessage</div>
    }
    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
    <div class="cart-panel table-responsive">
        <table class="table align-middle">
            <thead><tr><th>Product</th><th>Quantity</th><th>Unit Price</th><th>Subtotal</th><th></th></tr></thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr><td colspan="5">Your cart is empty.</td></tr>
                }
                else
                {
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.ProductName</td>
                            <td><input class="form-control qty" type="number" value="@item.Quantity" min="1" readonly /></td>
                            <td>@item.UnitPrice.ToString("C")</td>
                            <td>@item.LineTotal.ToString("C")</td>
                            <td><button class="btn btn-sm btn-outline-danger" disabled>Delete</button></td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <div class="cart-summary">
        <span>Total Amount</span>
        <strong>@Model.TotalAmount.ToString("C")</strong>
        <a class="btn btn-primary btn-lg @(Model.Items.Any() ? "" : "disabled")" asp-controller="Customer" asp-action="Checkout">Proceed to Checkout</a>
    </div>
</section>
