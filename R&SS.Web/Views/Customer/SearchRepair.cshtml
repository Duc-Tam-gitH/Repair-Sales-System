@model IReadOnlyCollection<ServiceRequestResponse>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Search Technical Order";
    ViewData["ActiveRole"] = "Customer";
    ViewData["RoleDisplay"] = "Customer User";
}

@section Styles {
    <link rel="stylesheet" href="~/css/SearchRepair.css" asp-append-version="true" />
}

<section class="search-repair-page">
    <div class="search-card">
        <h1>Search Technical Order</h1>
        <p>Enter your service request code to check repair intake status.</p>
        @if (TempData["SuccessMessage"] is string successMessage)
        {
            <div class="alert alert-success" role="status">@successMessage</div>
        }
        <form class="input-group input-group-lg" method="get" asp-controller="Customer" asp-action="SearchRepair">
            <input class="form-control" name="keyword" value="@ViewData["Keyword"]" placeholder="Request Code, e.g., SR-202607..." />
            <button class="btn btn-primary" type="submit">Search</button>
        </form>
    </div>

    @if (!Model.Any())
    {
        <div class="result-card"><h2>No repair requests found</h2></div>
    }
    else
    {
        @foreach (var request in Model)
        {
            <div class="result-card">
                <div>
                    <span>Repair Status</span>
                    <h2>@request.Status</h2>
                </div>
                <div class="row g-3">
                    <div class="col-md-6"><strong>Request Code</strong><p>@request.RequestCode</p></div>
                    <div class="col-md-6"><strong>Device Information</strong><p>@request.Brand @request.DeviceModel - @request.DeviceType</p></div>
                    <div class="col-md-6"><strong>Service Type</strong><p>@request.ServiceType</p></div>
                    <div class="col-md-6"><strong>Latest Note</strong><p>@request.Description</p></div>
                </div>
            </div>
        }
    }
</section>
